                                <div class="form-group" style="margin-bottom: 12px;">
                                    <label class="form-label" style="font-size: 12px;">Quantity</label>
                                    <input type="number" class="form-input" name="qty_saluyot" placeholder="0" min="1" style="height: 40px;">
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label class="form-label" style="font-size: 12px;">Unit</label>
                                    <div class="flex-row">
                                        <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;">
                                            <input type="radio" name="unit_saluyot" value="packets" checked> Packet
                                        </label>
                                        <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;">
