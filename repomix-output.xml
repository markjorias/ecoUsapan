    cursor: pointer;
}

.checkbox-label input[type="checkbox"], .checkbox-label input[type="radio"] {
    accent-color: var(--primary-color);
    width: 18px;
    height: 18px;
}

/* Bottom Action */
.bottom-action-container {
    width: 100%;
    /* Static position implicitly via flow, just add margin/padding if needed */
    padding: 24px 0; /* Vertical padding, horizontal implied by parent padding */
    margin-top: auto; /* Push to bottom if space is available (using flex) */
    display: flex;
    justify-content: center;
}

.action-btn {
    width: 100%;
    height: 50px;
    background: var(--primary-color);
    color: white;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
}

.action-btn:hover {
    background: #3d8b20;
}

/* Disclaimer Text */
.disclaimer-text {
    font-size: 12px;
    color: #666;
    line-height: 1.5;
    background: #f9f9f9;
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
}

.disclaimer-text p {
    margin: 0 0 10px 0;
}

/* Upload Styling */
.upload-container {
    border: 2px dashed #D1D1D6;
    border-radius: 12px;
    padding: 24px;
    text-align: center; /* Center content */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #fafafa;
    cursor: pointer;
    transition: all 0.2s;
}

.upload-container:hover {
    border-color: var(--primary-color);
    background: #f0f9eb;
}

.upload-icon {
    width: 24px;
    height: 24px;
    opacity: 0.5;
}

.upload-text {
    font-size: 14px;
    color: #8E8E93;
    font-weight: 500;
}

.section-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--primary-color);
    text-transform: uppercase;
}

/* Multi-step list specific */
.crop-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.crop-item {
    border: 1px solid #E5E5EA;
    border-radius: 12px;
    padding: 16px;
    background: #fff;
    transition: all 0.2s;
}

.crop-item.selected {
    border-color: var(--primary-color);
    background: #F9FFF9;
}

.crop-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
}

.crop-title {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
    gap: 10px;
}

.crop-details {
    margin-top: 16px;
    display: none;
    padding-top: 16px;
    border-top: 1px solid #eee;
}

.crop-item.selected .crop-details {
    display: block;
}

/* Mobile Responsive */
@media (max-width: 500px) {
    .app-container {
        width: 100%;
        height: 100vh;
        border: none;
        border-radius: 0;
        padding-top: env(safe-area-inset-top, 20px);
    }
    /* scroll-content padding remains as defined in base styles (74px top), 
       but since we added padding to app-container, we might need to adjust.
       In about-ecoservice.css, scroll-content keeps 74px + app-container 20px? 
       Let's assume about-ecoservice.css behavior is correct reference.
       It does NOT modify scroll-content in media query. 
    */
}
