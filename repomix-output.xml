<file path="webapp/templates/login.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Login - EcoUsapan Prototype</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
    <style>
        .login-scroll { width: 100%; overflow-y: auto; display: flex; flex-direction: column; align-items: center; padding: 20px 0; }
        .login-card { width: 100%; padding: 16px; background: #f9f9f9; border-radius: 12px; text-align: left; border: 1px solid #eee; margin-bottom: 12px; cursor: pointer; transition: all 0.2s ease; display: flex; flex-direction: column; }
        .login-card:hover { border-color: #49A427; background: #f0f9ed; }
        .login-card.admin { border-left: 5px solid #000; }
        .login-card.user { border-left: 5px solid #49A427; }
        .add-user-card { width: 100%; padding: 16px; background: #fff; border-radius: 12px; text-align: center; border: 2px dashed #49A427; margin-bottom: 24px; cursor: pointer; color: #49A427; font-weight: 700; font-size: 14px; }
        .role-tag { font-size: 9px; text-transform: uppercase; font-weight: 800; color: #666; margin-bottom: 4px; }
        .section-label { width: 100%; font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; margin-bottom: 12px; letter-spacing: 1px; }
    </style>
</head>
<body>
    <div class="app-container" style="padding: 40px 24px; background: #fff; justify-content: flex-start;">
        <div class="login-scroll">
            <img src="{{ url_for('static', filename='images/ecoUsapan_logo.png') }}" alt="Logo" style="width: 150px; margin-bottom: 30px;">
            
            <h2 style="font-size: 18px; font-weight: 700; margin-bottom: 4px; width: 100%;">Select Account</h2>
            <p style="font-size: 12px; color: #666; margin-bottom: 24px; width: 100%;">Choose a profile to enter the prototype.</p>

            <form action="{{ url_for('auth.login') }}" method="POST" id="loginForm">
                <input type="hidden" name="email" id="loginEmail">
                
                <div class="section-label">Administrators</div>
                {% for admin in admins %}
                <div class="login-card admin" onclick="loginAs('{{ admin.email }}')">
                    <div class="role-tag">{{ admin.role.replace('Admin_', '') }} Access</div>
                    <div style="font-size: 16px; font-weight: 700;">{{ admin.username }}</div>
                    <div style="font-size: 11px; color: #888;">{{ admin.email }}</div>
                </div>
                {% endfor %}

                <div class="section-label" style="margin-top: 12px;">Standard Users</div>
                {% for u in users %}
                <div class="login-card user" onclick="loginAs('{{ u.email }}')">
                    <div class="role-tag" style="color: #49A427;">Standard Access</div>
                    <div style="font-size: 16px; font-weight: 700;">{{ u.username }}</div>
                    <div style="font-size: 11px; color: #888;">{{ u.email }}</div>
                </div>
                {% endfor %}
            </form>

            <a href="{{ url_for('auth.add_test_user') }}" style="text-decoration: none; width: 100%;">
                <div class="add-user-card">+ Add New Test User</div>
            </a>
        </div>
    </div>

    <script>
        function loginAs(email) {
            document.getElementById('loginEmail').value = email;
            document.getElementById('loginForm').submit();
        }
    </script>
</body>
</html>
</file>

<file path="webapp/templates/request-seedlings-form.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Request Seedlings</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/request-seeds-form.css') }}">
    <style>
        .error-message {
            color: #ff5252;
            font-size: 11px;
            font-weight: 700;
            margin-top: 4px;
            display: none;
        }
        .form-group.invalid .form-input {
            border-color: #ff5252;
        }
        .form-group.invalid .error-message {
            display: block;
        }
    </style>
</head>
<body>
    <div class="app-container">
        
        <form id="seedlingRequestForm" method="POST" action="{{ url_for('views.request_seedlings_form') }}" class="scroll-content" enctype="multipart/form-data">
            
            <!-- Header -->
            <div class="form-header">
                <a href="{{ url_for('views.about_ecoservice_seedlings') }}" class="close-btn">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" alt="Back">
                </a>
                <h1 id="header-title">Request Form</h1>
            </div>

            <!-- Step 1: Select Seedlings -->
            <div class="form-step active" id="step1">
                <div class="form-container">
                    <h2 class="section-title">Step 1: Select Seedlings</h2>
                    <p style="font-size: 13px; color: #666; margin-bottom: 16px;">Select the tree seedlings you need and specify the quantity.</p>

                    <div class="crop-list">
                        {% for seedling in seedlings %}
                        <div class="crop-item" id="item-{{ seedling.id }}">
                            <label class="crop-header">
                                <div class="crop-title">
                                    <input type="checkbox" name="seedlings" value="{{ seedling.id }}" onchange="toggleItemDetails(this, 'details-{{ seedling.id }}', 'item-{{ seedling.id }}')">
                                    {{ seedling.name }}
                                </div>
                            </label>
                            <div class="crop-details" id="details-{{ seedling.id }}">
                                <div class="form-group" style="margin-bottom: 12px;">
                                    <label class="form-label" style="font-size: 12px;">Quantity (In stock: {{ seedling.stock_quantity }} pots)</label>
                                    <input type="number" class="form-input" name="qty_{{ seedling.id }}" placeholder="0" min="1" max="{{ seedling.stock_quantity }}" style="height: 40px;">
                                    <span class="error-message">Please enter a valid quantity.</span>
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label class="form-label" style="font-size: 12px;">Unit</label>
                                    <div class="flex-row">
                                        <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;">
                                            <input type="radio" name="unit_{{ seedling.id }}" value="pots" checked> Pot
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% else %}
                        <p style="text-align: center; color: #999; padding: 20px;">No seedlings currently available in the nursery stock.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Step 2: Requester Info -->
            <div class="form-step" id="step2">
                <div class="form-container">
                    <h2 class="section-title">Step 2: Requester Info</h2>

                    <div class="form-group">
                        <label class="form-label">Full Name of Requester</label>
                        <div class="flex-row gap-12">
                            <input type="text" name="first_name" class="form-input" placeholder="First Name">
                            <input type="text" name="last_name" class="form-input" placeholder="Last Name">
                        </div>
                        <span class="error-message">Both first and last names are required.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Group Name (optional)</label>
                        <input type="text" name="group_name" class="form-input" placeholder="Organization or Group Name">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Requester Type</label>
                        <div class="chips-container">
                            <label>
                                <input type="radio" name="requesterType" value="Individual grower" class="chip-option">
                                <span class="chip">Individual grower</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Volunteer group member" class="chip-option">
                                <span class="chip">Volunteer group</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Community member" class="chip-option">
                                <span class="chip">Community member</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Student or youth group" class="chip-option">
                                <span class="chip">Student/Youth group</span>
                            </label>
                        </div>
                        <span class="error-message">Please select a requester type.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Contact Information</label>
                        <input type="tel" name="phone" class="form-input" placeholder="Mobile Number" style="margin-bottom: 12px;">
                        <input type="email" name="email" class="form-input" placeholder="Email Address (optional)">
                        <span class="error-message">A valid mobile number is required.</span>
                    </div>
                </div>
            </div>

            <!-- Step 3: Details & Plan -->
            <div class="form-step" id="step3">
                 <div class="form-container">
                    <h2 class="section-title">Step 3: Details & Plan</h2>

                    <div class="form-group">
                        <label class="form-label">Location of Planting Site</label>
                        <input type="text" name="province" class="form-input" placeholder="Province" style="margin-bottom: 8px;">
                        <input type="text" name="city" class="form-input" placeholder="Municipality / City" style="margin-bottom: 8px;">
                        <input type="text" name="barangay" class="form-input" placeholder="Barangay">
                        <span class="error-message">Please provide complete location details.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Type of Planting Area</label>
                         <div class="chips-container">
                            <label>
                                <input type="radio" name="areaType" value="Backyard" class="chip-option">
                                <span class="chip">Backyard</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Community Space" class="chip-option">
                                <span class="chip">Community Space</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="School grounds" class="chip-option">
                                <span class="chip">School grounds</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Reforestation plot" class="chip-option">
                                <span class="chip">Reforestation plot</span>
                            </label>
                        </div>
                        <span class="error-message">Please select the type of planting area.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Intended Purpose*</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Reforestation">
                                Reforestation
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Community greening">
                                Community greening
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Watershed protection">
                                Watershed protection
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Urban gardening">
                                Urban gardening
                            </label>
                        </div>
                        <span class="error-message">Select at least one intended purpose.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" style="margin-bottom: 12px; display: block;">Brief Description of Your Greening Plan*</label>
                        <textarea name="plan_desc" class="form-textarea" placeholder="Describe how these seedlings will contribute to your local environment..." style="height: 100px;"></textarea>
                        <span class="error-message">Please provide a description of your plan.</span>
                    </div>
                </div>
            </div>

            <!-- Step 4: Uploads & Confirm -->
            <div class="form-step" id="step4">
                 <div class="form-container">
                    <h2 class="section-title">Step 4: Uploads & Confirm</h2>
                    
                    <p style="font-size: 13px; color: #666; margin-bottom: 16px;">Please upload a photo of the planting area.</p>

                    <div class="form-group" style="margin-bottom: 24px;">
                        <div class="upload-container" id="uploadBox" onclick="document.getElementById('fileUpload').click()">
                            <img src="{{ url_for('static', filename='icons/image.svg') }}" class="upload-icon" alt="Upload">
                            <div class="upload-text" id="uploadText">Tap to upload JPG / PNG</div>
                            <input type="file" id="fileUpload" name="site_photo" hidden accept="image/png, image/jpeg" onchange="updateUploadText(this)">
                        </div>
                        <span class="error-message">A photo of the planting site is required.</span>
                    </div>

                    <div class="form-group" style="margin-bottom: 24px;">
                         <label class="form-label">Commitment Statement*</label>
                         <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" class="commitment-check">
                                I will ensure the survival of the seedlings
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" class="commitment-check">
                                I understand seedlings are not for resale
                            </label>
                             <label class="checkbox-label">
                                <input type="checkbox" id="verifyCheck" class="commitment-check">
                                I verify that this request is accurate.
                            </label>
                         </div>
                         <span class="error-message">All commitment boxes must be checked.</span>
                    </div>
                </div>
            </div>

            <!-- Bottom Action -->
            <div class="bottom-action-container">
                <button type="button" class="action-btn" id="nextBtn" style="background: #004D40;" onclick="nextStep()">NEXT</button>
            </div>

        </form>
    </div>

    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function updateView() {
            document.querySelectorAll('.form-step').forEach(step => {
                step.classList.remove('active');
            });
            document.getElementById('step' + currentStep).classList.add('active');

            const closeBtn = document.querySelector('.close-btn');
            const icon = closeBtn.querySelector('img');

            if (currentStep === 1) {
                icon.src = "{{ url_for('static', filename='icons/x.svg') }}";
                closeBtn.href = "{{ url_for('views.about_ecoservice_seedlings') }}";
                closeBtn.onclick = null;
            } else {
                icon.src = "{{ url_for('static', filename='icons/chevron-left.svg') }}";
                closeBtn.removeAttribute('href');
                closeBtn.onclick = function(e) {
                    e.preventDefault();
                    prevStep();
                };
            }

            const btn = document.getElementById('nextBtn');
            btn.textContent = (currentStep === totalSteps) ? "FINISH" : "NEXT";
            btn.onclick = (currentStep === totalSteps) ? finishForm : nextStep;
        }

        function validateStep() {
            // Remove previous error states
            document.querySelectorAll('.form-group').forEach(el => el.classList.remove('invalid'));

            if (currentStep === 1) {
                const checked = document.querySelectorAll('input[name="seedlings"]:checked');
                if (checked.length === 0) {
                    alert("Please select at least one seedling type.");
                    return false;
                }
                let qtyValid = true;
                checked.forEach(cb => {
                    const qtyInput = document.querySelector(`input[name="qty_${cb.value}"]`);
                    const val = parseInt(qtyInput.value);
                    const max = parseInt(qtyInput.max);
                    const errorMsg = qtyInput.closest('.form-group').querySelector('.error-message');

                    if (!qtyInput.value || val <= 0) {
                        errorMsg.textContent = "Please enter a valid quantity.";
                        qtyInput.closest('.form-group').classList.add('invalid');
                        qtyValid = false;
                    } else if (val > max) {
                        errorMsg.textContent = `Quantity exceeds available stock (${max}).`;
                        qtyInput.closest('.form-group').classList.add('invalid');
                        qtyValid = false;
                    }
                });
                return qtyValid;
            }

            if (currentStep === 2) {
                const fname = document.querySelector('input[name="first_name"]').value;
                const lname = document.querySelector('input[name="last_name"]').value;
                const type = document.querySelector('input[name="requesterType"]:checked');
                const phone = document.querySelector('input[name="phone"]').value;

                let isValid = true;
                if (!fname || !lname) {
                    document.querySelector('input[name="first_name"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!type) {
                    document.querySelector('.chips-container').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!phone) {
                    document.querySelector('input[name="phone"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                return isValid;
            }

            if (currentStep === 3) {
                const prov = document.querySelector('input[name="province"]').value;
                const city = document.querySelector('input[name="city"]').value;
                const brgy = document.querySelector('input[name="barangay"]').value;
                const area = document.querySelector('input[name="areaType"]:checked');
                const use = document.querySelectorAll('input[name="intendedUse"]:checked');
                const plan = document.querySelector('textarea[name="plan_desc"]').value;

                let isValid = true;
                if (!prov || !city || !brgy) {
                    document.querySelector('input[name="province"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!area) {
                    document.querySelector('input[name="areaType"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (use.length === 0) {
                    document.querySelector('.checkbox-group').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!plan || plan.trim().length < 10) {
                    document.querySelector('textarea[name="plan_desc"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                return isValid;
            }

            return true;
        }

        function nextStep() {
            if (validateStep()) {
                currentStep++;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                currentStep--;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function updateUploadText(input) {
            const text = document.getElementById('uploadText');
            if (input.files && input.files[0]) {
                text.textContent = input.files[0].name;
                text.style.color = "#004D40";
            }
        }

        function finishForm() {
            const photo = document.getElementById('fileUpload').files.length > 0;
            const commitments = document.querySelectorAll('.commitment-check:not(:checked)').length === 0;

            let isValid = true;
            if (!photo) {
                document.getElementById('uploadBox').closest('.form-group').classList.add('invalid');
                isValid = false;
            }
            if (!commitments) {
                document.querySelector('.commitment-check').closest('.form-group').classList.add('invalid');
                isValid = false;
            }

            if (isValid) {
                document.getElementById('seedlingRequestForm').submit();
            }
        }

        function toggleItemDetails(checkbox, detailsId, itemId) {
            const details = document.getElementById(detailsId);
            const item = document.getElementById(itemId);
            if (checkbox.checked) {
                item.classList.add('selected');
                const input = details.querySelector('input[type="number"]');
                if(input) input.focus();
            } else {
                item.classList.remove('selected');
                item.classList.remove('invalid');
            }
        }

        document.addEventListener('DOMContentLoaded', updateView);
    </script>
</body>
</html>
</file>

<file path="webapp/templates/request-seeds-form.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Request Seeds</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/request-seeds-form.css') }}">
    <style>
        .error-message {
            color: #ff5252;
            font-size: 11px;
            font-weight: 700;
            margin-top: 4px;
            display: none;
        }
        .form-group.invalid .form-input {
            border-color: #ff5252;
        }
        .form-group.invalid .error-message {
            display: block;
        }
    </style>
</head>
<body>
    <div class="app-container">
        
        <form id="seedRequestForm" method="POST" action="{{ url_for('views.request_seeds_form') }}" class="scroll-content" enctype="multipart/form-data">
            
            <!-- Header -->
            <div class="form-header">
                <a href="{{ url_for('views.about_ecoservice_seeds') }}" class="close-btn">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" alt="Back">
                </a>
                <h1 id="header-title">Request Form</h1>
            </div>

            <!-- Step 1: Select Crops -->
            <div class="form-step active" id="step1">
                <div class="form-container">
                    <h2 class="section-title">Step 1: Select Crops</h2>
                    <p style="font-size: 13px; color: #666; margin-bottom: 16px;">Select the crops you need and specify the quantity.</p>

                    <div class="crop-list">
                        {% for seed in seeds %}
                        <div class="crop-item" id="crop-{{ seed.id }}">
                            <label class="crop-header">
                                <div class="crop-title">
                                    <input type="checkbox" name="crops" value="{{ seed.id }}" onchange="toggleCropDetails(this, 'details-{{ seed.id }}', 'crop-{{ seed.id }}')">
                                    {{ seed.name }}
                                </div>
                            </label>
                            <div class="crop-details" id="details-{{ seed.id }}">
                                <div class="form-group" style="margin-bottom: 12px;">
                                    <label class="form-label" style="font-size: 12px;">Quantity (In stock: {{ seed.stock_quantity }} packets)</label>
                                    <input type="number" class="form-input" name="qty_{{ seed.id }}" placeholder="0" min="1" max="{{ seed.stock_quantity }}" style="height: 40px;">
                                    <span class="error-message">Please enter a valid quantity.</span>
                                </div>
                                <div class="form-group" style="margin-bottom: 0;">
                                    <label class="form-label" style="font-size: 12px;">Unit</label>
                                    <div class="flex-row">
                                        <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;">
                                            <input type="radio" name="unit_{{ seed.id }}" value="packets" checked> Packet
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% else %}
                        <p style="text-align: center; color: #999; padding: 20px;">No seeds currently available in stock.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Step 2: Requester Info -->
            <div class="form-step" id="step2">
                <div class="form-container">
                    <h2 class="section-title">Step 2: Requester Info</h2>

                    <div class="form-group">
                        <label class="form-label">Full Name of Requester</label>
                        <div class="flex-row gap-12">
                            <input type="text" name="first_name" class="form-input" placeholder="First Name">
                            <input type="text" name="last_name" class="form-input" placeholder="Last Name">
                        </div>
                        <span class="error-message">Both first and last names are required.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Group Name (optional)</label>
                        <input type="text" name="group_name" class="form-input" placeholder="Organization or Group Name">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Requester Type</label>
                        <div class="chips-container">
                            <label>
                                <input type="radio" name="requesterType" value="Individual grower" class="chip-option">
                                <span class="chip">Individual grower</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Backyard farmer" class="chip-option">
                                <span class="chip">Backyard farmer</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Community garden member" class="chip-option">
                                <span class="chip">Community member</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Student or youth group" class="chip-option">
                                <span class="chip">Student/Youth group</span>
                            </label>
                        </div>
                        <span class="error-message">Please select a requester type.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Contact Information</label>
                        <input type="tel" name="phone" class="form-input" placeholder="Mobile Number" style="margin-bottom: 12px;">
                        <input type="email" name="email" class="form-input" placeholder="Email Address (optional)">
                        <span class="error-message">A valid mobile number is required.</span>
                    </div>
                </div>
            </div>

            <!-- Step 3: Details & Plan -->
            <div class="form-step" id="step3">
                 <div class="form-container">
                    <h2 class="section-title">Step 3: Details & Plan</h2>

                    <div class="form-group">
                        <label class="form-label">Location of Farm / Garden</label>
                        <input type="text" name="province" class="form-input" placeholder="Province" style="margin-bottom: 8px;">
                        <input type="text" name="city" class="form-input" placeholder="Municipality / City" style="margin-bottom: 8px;">
                        <input type="text" name="barangay" class="form-input" placeholder="Barangay">
                        <span class="error-message">Please provide complete location details.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Type of Growing Area</label>
                         <div class="chips-container">
                            <label>
                                <input type="radio" name="areaType" value="Backyard" class="chip-option">
                                <span class="chip">Backyard</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Community garden" class="chip-option">
                                <span class="chip">Community garden</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="School garden" class="chip-option">
                                <span class="chip">School garden</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Small farm plot" class="chip-option">
                                <span class="chip">Small farm plot</span>
                            </label>
                        </div>
                        <span class="error-message">Please select the type of growing area.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Intended Use of Crops*</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Household consumption">
                                Household consumption
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Community sharing">
                                Community sharing
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Feeding programs">
                                Feeding programs
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Local selling">
                                Local selling (small-scale only)
                            </label>
                        </div>
                        <span class="error-message">Select at least one intended use.</span>
                    </div>

                    <div class="form-group">
                        <label class="form-label" style="margin-bottom: 12px; display: block;">Brief Description of Your Growing Plan*</label>
                        <textarea name="plan_desc" class="form-textarea" placeholder="Example: “We will plant vegetables in our community garden to support local food needs.”" style="height: 100px;"></textarea>
                        <span class="error-message">Please provide a description of your plan.</span>
                    </div>
                </div>
            </div>

            <!-- Step 4: Uploads & Confirm -->
            <div class="form-step" id="step4">
                 <div class="form-container">
                    <h2 class="section-title">Step 4: Uploads & Confirm</h2>
                    
                    <p style="font-size: 13px; color: #666; margin-bottom: 16px;">Please upload a photo of your growing area.</p>

                    <div class="form-group" style="margin-bottom: 24px;">
                        <div class="upload-container" id="uploadBox" onclick="document.getElementById('fileUpload').click()">
                            <img src="{{ url_for('static', filename='icons/image.svg') }}" class="upload-icon" alt="Upload">
                            <div class="upload-text" id="uploadText">Tap to upload JPG / PNG</div>
                            <input type="file" id="fileUpload" name="site_photo" hidden accept="image/png, image/jpeg" onchange="updateUploadText(this)">
                        </div>
                        <span class="error-message">A photo of the planting site is required.</span>
                    </div>

                    <div class="form-group" style="margin-bottom: 24px;">
                         <label class="form-label">Commitment Statement*</label>
                         <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" class="commitment-check">
                                I will use the seeds responsibly
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" class="commitment-check">
                                I understand seeds are not for resale
                            </label>
                             <label class="checkbox-label">
                                <input type="checkbox" id="verifyCheck" class="commitment-check">
                                I verify that this request is accurate.
                            </label>
                         </div>
                         <span class="error-message">All commitment boxes must be checked.</span>
                    </div>
                </div>
            </div>

            <!-- Bottom Action -->
            <div class="bottom-action-container">
                <button type="button" class="action-btn" id="nextBtn" onclick="nextStep()">NEXT</button>
            </div>

        </form>
    </div>

    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function updateView() {
            document.querySelectorAll('.form-step').forEach(step => {
                step.classList.remove('active');
            });
            document.getElementById('step' + currentStep).classList.add('active');

            const closeBtn = document.querySelector('.close-btn');
            const icon = closeBtn.querySelector('img');

            if (currentStep === 1) {
                icon.src = "{{ url_for('static', filename='icons/x.svg') }}";
                closeBtn.href = "{{ url_for('views.about_ecoservice_seeds') }}";
                closeBtn.onclick = null;
            } else {
                icon.src = "{{ url_for('static', filename='icons/chevron-left.svg') }}";
                closeBtn.removeAttribute('href');
                closeBtn.onclick = function(e) {
                    e.preventDefault();
                    prevStep();
                };
            }

            const btn = document.getElementById('nextBtn');
            btn.textContent = (currentStep === totalSteps) ? "FINISH" : "NEXT";
            btn.onclick = (currentStep === totalSteps) ? finishForm : nextStep;
        }

        function validateStep() {
            // Remove previous error states
            document.querySelectorAll('.form-group').forEach(el => el.classList.remove('invalid'));

            if (currentStep === 1) {
                const checked = document.querySelectorAll('input[name="crops"]:checked');
                if (checked.length === 0) {
                    alert("Please select at least one crop.");
                    return false;
                }
                let qtyValid = true;
                checked.forEach(cb => {
                    const qtyInput = document.querySelector(`input[name="qty_${cb.value}"]`);
                    const val = parseInt(qtyInput.value);
                    const max = parseInt(qtyInput.max);
                    const errorMsg = qtyInput.closest('.form-group').querySelector('.error-message');

                    if (!qtyInput.value || val <= 0) {
                        errorMsg.textContent = "Please enter a valid quantity.";
                        qtyInput.closest('.form-group').classList.add('invalid');
                        qtyValid = false;
                    } else if (val > max) {
                        errorMsg.textContent = `Quantity exceeds available stock (${max}).`;
                        qtyInput.closest('.form-group').classList.add('invalid');
                        qtyValid = false;
                    }
                });
                return qtyValid;
            }

            if (currentStep === 2) {
                const fname = document.querySelector('input[name="first_name"]').value;
                const lname = document.querySelector('input[name="last_name"]').value;
                const type = document.querySelector('input[name="requesterType"]:checked');
                const phone = document.querySelector('input[name="phone"]').value;

                let isValid = true;
                if (!fname || !lname) {
                    document.querySelector('input[name="first_name"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!type) {
                    document.querySelector('.chips-container').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!phone) {
                    document.querySelector('input[name="phone"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                return isValid;
            }

            if (currentStep === 3) {
                const prov = document.querySelector('input[name="province"]').value;
                const city = document.querySelector('input[name="city"]').value;
                const brgy = document.querySelector('input[name="barangay"]').value;
                const area = document.querySelector('input[name="areaType"]:checked');
                const use = document.querySelectorAll('input[name="intendedUse"]:checked');
                const plan = document.querySelector('textarea[name="plan_desc"]').value;

                let isValid = true;
                if (!prov || !city || !brgy) {
                    document.querySelector('input[name="province"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!area) {
                    document.querySelector('input[name="areaType"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (use.length === 0) {
                    document.querySelector('.checkbox-group').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                if (!plan || plan.trim().length < 10) {
                    document.querySelector('textarea[name="plan_desc"]').closest('.form-group').classList.add('invalid');
                    isValid = false;
                }
                return isValid;
            }

            return true;
        }

        function nextStep() {
            if (validateStep()) {
                currentStep++;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                currentStep--;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function updateUploadText(input) {
            const text = document.getElementById('uploadText');
            if (input.files && input.files[0]) {
                text.textContent = input.files[0].name;
                text.style.color = "#49A427";
            }
        }

        function finishForm() {
            const photo = document.getElementById('fileUpload').files.length > 0;
            const commitments = document.querySelectorAll('.commitment-check:not(:checked)').length === 0;

            let isValid = true;
            if (!photo) {
                document.getElementById('uploadBox').closest('.form-group').classList.add('invalid');
                isValid = false;
            }
            if (!commitments) {
                document.querySelector('.commitment-check').closest('.form-group').classList.add('invalid');
                isValid = false;
            }

            if (isValid) {
                document.getElementById('seedRequestForm').submit();
            }
        }

        function toggleCropDetails(checkbox, detailsId, itemId) {
            const details = document.getElementById(detailsId);
            const item = document.getElementById(itemId);
            if (checkbox.checked) {
                item.classList.add('selected');
                const input = details.querySelector('input[type="number"]');
                if(input) input.focus();
            } else {
                item.classList.remove('selected');
                item.classList.remove('invalid');
            }
        }

        document.addEventListener('DOMContentLoaded', updateView);
    </script>
</body>
</html>
