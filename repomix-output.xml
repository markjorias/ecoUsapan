<file path="webapp/static/css/request-form-seeds.css">
:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7;
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
    --primary-color: #49A427;
    --text-color: #333;
    --input-bg: #fff;
    --input-border: #D1D1D6;
    --input-focus: #49A427;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    border-radius: 40px;
    border: 8px solid #333;
    
    display: flex;
    flex-direction: column;
    align-items: center;
}

.scroll-content {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-bottom: 40px;
    padding-left: 19px;
    padding-right: 19px;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

/* Header inside scroll content style or fixed */
.form-header {
    width: 100%;
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    /* If we want it strictly at top, usually it's better inside scroll for this specific requested layout */
}

.close-btn {
    margin-right: 16px;
    display: flex;
    align-items: center;
    text-decoration: none;
}

.form-header h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0;
    color: #000;
}

/* Form Container */
.form-container {
    padding: 0;
    width: 100%;
}

/* Form Steps */
.form-step {
    display: none;
    width: 100%; /* Ensure it fills the flex parent */
    animation: fadeIn 0.3s ease-in-out;
}

.form-step.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Form Groups */
.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 24px;
}

.form-label {
    font-size: 14px;
    font-weight: 700;
    color: #000;
}

.form-input, .form-select, .form-textarea {
    width: 100%;
    height: 48px;
    padding: 12px 16px;
    border: 1px solid var(--input-border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    color: #333;
    background-color: #fff;
    transition: border-color 0.2s;
}

.form-input:focus, .form-select:focus, .form-textarea:focus {
    outline: none;
    border-color: var(--input-focus);
}

.form-textarea {
    resize: none;
    height: 140px;
}

/* Flex Helpers */
.flex-row {
    display: flex;
    gap: 12px;
}

.gap-12 {
    gap: 12px;
}

/* Chips - Matching launch_initiative.css */
.chips-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.chip-option {
    display: none;
}

.chip {
    padding: 0 16px;
    border: 1px solid #E5E5EA;
    border-radius: 20px;
    background-color: #FFFFFF;
    font-size: 11px;
    font-weight: 400;
    color: #666;
    cursor: pointer;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    /* Flex grow to fill space nicely, resembling the grid */
    flex: 1 0 auto; 
    min-width: 80px; 
}

.chip-option:checked + .chip {
    background: #49A427;
    color: #fff;
    border-color: #49A427;
    font-weight: 600;
}


/* Checkboxes & Radios */
.checkbox-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.checkbox-label {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: #444;
    cursor: pointer;
}

.checkbox-label input[type="checkbox"], .checkbox-label input[type="radio"] {
    accent-color: var(--primary-color);
    width: 18px;
    height: 18px;
}

/* Bottom Action */
.bottom-action-container {
    width: 100%;
    /* Static position implicitly via flow, just add margin/padding if needed */
    padding: 24px 0; /* Vertical padding, horizontal implied by parent padding */
    margin-top: auto; /* Push to bottom if space is available (using flex) */
    display: flex;
    justify-content: center;
}

.action-btn {
    width: 100%;
    height: 50px;
    background: var(--primary-color);
    color: white;
    font-size: 14px;
    font-weight: 700;
    text-align: center;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    text-transform: uppercase;
}

.action-btn:hover {
    background: #3d8b20;
}

/* Disclaimer Text */
.disclaimer-text {
    font-size: 12px;
    color: #666;
    line-height: 1.5;
    background: #f9f9f9;
    padding: 16px;
    border-radius: 8px;
    margin-bottom: 20px;
}

.disclaimer-text p {
    margin: 0 0 10px 0;
}

/* Upload Styling */
.upload-container {
    border: 2px dashed #D1D1D6;
    border-radius: 12px;
    padding: 24px;
    text-align: center; /* Center content */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    background: #fafafa;
    cursor: pointer;
    transition: all 0.2s;
}

.upload-container:hover {
    border-color: var(--primary-color);
    background: #f0f9eb;
}

.upload-icon {
    width: 24px;
    height: 24px;
    opacity: 0.5;
}

.upload-text {
    font-size: 14px;
    color: #8E8E93;
    font-weight: 500;
}

.section-title {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--primary-color);
    text-transform: uppercase;
}

/* Multi-step list specific */
.crop-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.crop-item {
    border: 1px solid #E5E5EA;
    border-radius: 12px;
    padding: 16px;
    background: #fff;
    transition: all 0.2s;
}

.crop-item.selected {
    border-color: var(--primary-color);
    background: #F9FFF9;
}

.crop-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
}

.crop-title {
    font-size: 16px;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
    gap: 10px;
}

.crop-details {
    margin-top: 16px;
    display: none;
    padding-top: 16px;
    border-top: 1px solid #eee;
}

.crop-item.selected .crop-details {
    display: block;
}

/* Mobile Responsive */
@media (max-width: 500px) {
    .app-container {
        width: 100%;
        height: 100vh;
        border: none;
        border-radius: 0;
        padding-top: env(safe-area-inset-top, 20px);
    }
    /* scroll-content padding remains as defined in base styles (74px top), 
       but since we added padding to app-container, we might need to adjust.
       In about-ecoservice.css, scroll-content keeps 74px + app-container 20px? 
       Let's assume about-ecoservice.css behavior is correct reference.
       It does NOT modify scroll-content in media query. 
    */
}
</file>

