                    {% else %}
                    <div class="featured-card active">
                        <img src="{{ url_for('static', filename='images/sample-image1.png') }}" class="featured-image">
                        <div class="featured-gradient-overlay"></div>
                        <div class="featured-info-overlay">
                            <div class="featured-tag">Welcome</div>
                            <div class="featured-title">Start an Initiative!</div>
                            <div class="featured-user">No events yet</div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                
                <div class="carousel-indicators">
                    {% for event in initiatives[:3] %}
                    <div class="indicator-pill {{ 'active' if loop.first }}" data-index="{{ loop.index0 }}">
