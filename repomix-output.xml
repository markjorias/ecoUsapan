                </div>
            </div>
            
            <!-- Dynamic Featured Carousel -->
            <div class="featured-carousel-container">
                <div class="featured-carousel" id="featuredCarousel">
                    {% for event in initiatives[:3] %}
                    <div class="featured-card {{ 'active' if loop.first }}" data-index="{{ loop.index0 }}">
                        <img src="{{ url_for('static', filename='uploads/' + event.image_filename) if event.image_filename != 'default_event.png' else url_for('static', filename='images/sample-image1.png') }}" alt="{{ event.title }}" class="featured-image">
