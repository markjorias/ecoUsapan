:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7;
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    border-radius: 40px;
    border: 8px solid #333;
    
    display: flex;
    flex-direction: column;
    align-items: center;
}

.scroll-content {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-bottom: 40px;
    padding-left: 19px;
    padding-right: 19px;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

