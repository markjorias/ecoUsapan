                        <!-- Guyabano -->
                        <div class="crop-item" id="crop-guyabano">
                            <label class="crop-header">
                                <div class="crop-title">
                                    <input type="checkbox" name="crops" value="Guyabano" onchange="toggleCropDetails(this, 'guyabano-details', 'crop-guyabano')">
