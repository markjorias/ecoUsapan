from flask import Flask
from flask_sqlalchemy import SQLAlchemy
from flask_login import LoginManager
from flask_migrate import Migrate
from werkzeug.security import generate_password_hash
import os

db = SQLAlchemy()

def create_app():
    app = Flask(__name__)
    app.config['SECRET_KEY'] = 'secretngani'
    
    root_path = os.path.abspath(os.path.dirname(os.path.dirname(__file__)))
    instance_path = os.path.join(root_path, 'instance')
    
    if not os.path.exists(instance_path):
        os.makedirs(instance_path)
    
    app.config['SQLALCHEMY_DATABASE_URI'] = 'sqlite:///' + os.path.join(instance_path, 'site.db')
    app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False

    db.init_app(app)

    migrate = Migrate(app, db)

    login_manager = LoginManager()
    login_manager.login_view = 'auth.login'
    login_manager.init_app(app)

    from .models import User

    @login_manager.user_loader
    def load_user(id):
        return User.query.get(int(id))

    from .views import views
    from .auth import auth
    app.register_blueprint(views, url_prefix='/')
    app.register_blueprint(auth, url_prefix='/')
    
    with app.app_context():
        db.create_all()
        
        # FIX: Changed 'is_admin=True' to 'role='Admin_LGU'' 
        # because is_admin is now a read-only property.
        if not User.query.filter_by(email='admin@ecousapan.com').first():
            admin = User(
                email='admin@ecousapan.com', 
                username='admin', 
                password=generate_password_hash('admin', method='pbkdf2:sha256'),
                role='Admin_LGU'
            )
            db.session.add(admin)
            
        if not User.query.filter_by(email='user@ecousapan.com').first():
            user = User(
                email='user@ecousapan.com', 
                username='tester', 
                password=generate_password_hash('user', method='pbkdf2:sha256'),
                role='User'
            )
            db.session.add(user)
            
        db.session.commit()
    
    return app
</file>

<file path="webapp/static/css/forum.css">
/* Forum Page Styles - EcoUsapan */

:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7;
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
    --eco-green: #49A427;
    --eco-light-green: #E8F5E9;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    border-radius: 40px;
    border: 8px solid #333;
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* Scrollable Container */
.scroll-content {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-bottom: 220px; /* Clearance for the 99px nav bar */
    padding-left: 19px;
    padding-right: 19px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px; 
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

/* Header */
.forum-header {
    display: flex;
    flex-direction: row;
    align-items: center;
    width: 100%;
    padding: 16px 0;
    gap: 16px;
}

.back-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
}

.back-btn img {
    width: 24px;
    height: 24px;
}

.header-title {
    font-size: 24px;
    font-weight: 700;
    margin: 0;
    color: #000;
    flex: 1;
}

/* Filter Dropdown Logic */
.filter-wrapper {
    position: relative;
    display: flex;
    align-items: center;
}

.filter-btn {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
}

.filter-btn img {
    width: 24px;
    height: 24px;
}

.filter-dropdown {
    position: absolute;
    top: 40px;
    right: 0;
    background: white;
    width: 160px;
    border-radius: 16px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    display: none; /* Controlled by JS */
    flex-direction: column;
    padding: 8px;
    z-index: 2500;
    border: 1px solid #eee;
}

.filter-option {
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 600;
    color: #444;
    cursor: pointer;
    border-radius: 10px;
    transition: 0.2s;
}

.filter-option.active {
    background: var(--eco-light-green);
    color: var(--eco-green);
}

.filter-option:hover {
    background: #f9f9f9;
}

/* Search and Add Topic Row */
.search-add-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
    width: 100%;
}

.search-container {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
    height: 49px;
    padding: 0 16px;
    border: 1px solid #E0E0E0;
    border-radius: 59px;
    background-color: #fff;
}

.search-icon {
    width: 20px;
    height: 20px;
}

.search-input {
    width: 100%;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 14px;
    background: transparent;
}

.search-input::placeholder {
    color: #9E9E9E;
}

.add-forum-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 49px;
    height: 49px;
    border: 1px solid #E0E0E0;
    border-radius: 50%;
    cursor: pointer;
    flex-shrink: 0;
    background-color: #fff;
}

.add-forum-icon {
    width: 24px;
    height: 24px;
}

/* Section Containers */
.forum-sections-wrapper {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
}

.forum-section-container {
    width: 100%;
    background-color: #FFFFFF;
    border-radius: 24px;
    padding: 16px;
    border: 1px solid #E0E0E0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
}

.section-title {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #333;
}

.forum-card-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
}

/* Forum Cards */
.forum-card1, .forum-card3 {
    width: 100%;
    min-height: 85px;
    height: auto; 
    padding: 12px 16px;
    background-color: #F9F9F9;
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: 12px;
    text-decoration: none;
}

.forum-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
}

.forum-tag {
    font-size: 8px;
    font-weight: 700;
    color: var(--eco-green);
    background-color: var(--eco-light-green);
    padding: 2px 6px;
    border-radius: 4px;
    text-transform: uppercase;
    width: fit-content;
}

.forum-title {
    font-size: 15px; 
    font-weight: 700;
    color: #000;
    line-height: 1.2;
}

.forum-meta {
    display: flex;
    align-items: center;
    gap: 8px;
}

.forum-username {
    font-size: 10px;
    font-weight: 600; 
    color: var(--eco-green);
}

.forum-comments {
    font-size: 10px;
    font-weight: 400;
    color: #666;
}

/* Voting UI */
.forum-action {
    flex-shrink: 0;
    cursor: pointer;
}

.vote-controls {
    display: flex;
    flex-direction: column; 
    justify-content: center;
    align-items: center;
    gap: 2px;
    padding: 6px 10px;
    background: #fff;
    border-radius: 10px;
    border: 1px solid #eee;
    transition: all 0.2s ease;
}

.vote-controls.voted {
    background-color: var(--eco-light-green);
    border-color: var(--eco-green);
}

.vote-controls.voted .vote-count {
    color: var(--eco-green);
}

.vote-controls.voted .vote-icon {
    filter: invert(48%) sepia(79%) saturate(452%) hue-rotate(65deg) brightness(95%) contrast(92%);
    /* This filter makes the black/grey icon turn the specific Eco Green color */
    transform: translateY(-2px);
}

.vote-controls:hover {
    background: #f0f0f0;
}

.vote-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.2s;
}

.vote-count {
    font-size: 10px;
    font-weight: 800;
    color: #333;
}

/* Modal Overlay & Content */
.modal-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
    display: none;
    justify-content: center;
    align-items: center;
    z-index: 2000;
    padding: 20px;
}

.modal-content {
    background: white;
    width: 100%;
    border-radius: 28px;
    padding: 24px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    position: relative;
}

.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
}

.modal-title {
    font-size: 20px;
    font-weight: 800;
    color: #333;
}

.modal-close {
    cursor: pointer;
    width: 24px;
    height: 24px;
}

.form-group {
    margin-bottom: 16px;
}

.form-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: #666;
    margin-bottom: 6px;
    text-transform: uppercase;
}

.form-input, .form-textarea, .form-select {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #E0E0E0;
    border-radius: 12px;
    font-family: inherit;
    font-size: 14px;
    outline: none;
}

.form-textarea {
    height: 120px;
    resize: none;
}

.submit-btn {
    width: 100%;
    padding: 14px;
    background-color: var(--eco-green);
    color: white;
    border: none;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
}

/* Navigation Bar */
.bottom-nav {
    width: 100%;
    height: 99px;
    background-color: #FFFFFF;
    display: flex;
    justify-content: space-around;
    align-items: flex-start;
    padding-top: 15px;
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 1000;
    border-top: 1px solid #E5E5EA;
}

.nav-bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    color: #8E8E93;
    width: 60px;
    text-decoration: none;
}

.nav-bar-item.active {
    color: var(--eco-green);
}

.nav-bar-icon svg {
    width: 24px;
    height: 24px;
}

.nav-bar-label {
    font-size: 10px;
    font-weight: 500;
}

.nav-center-item {
    width: 52px;
    height: 52px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: -10px;
    text-decoration: none;
}

.nav-center-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

/* Responsive Fix for small screens */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh;
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px);
    }
}
</file>

