<file path="webapp/templates/launch_initiative1.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Launch Your Initiative</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/launch_initiative.css') }}">
</head>
<body>
    <div class="app-container">
        <form method="POST" action="{{ url_for('views.launch_initiative1') }}" class="scroll-content" style="padding-bottom: 40px;">
            <div class="launch-header">
        <div class="scroll-content" style="padding-bottom: 40px;"><div class="launch-header">
                <a href="{{ url_for('views.home') }}" class="close-btn">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" alt="Close">
                </a>
                <h1>Launch Your Initiative</h1>
            </div>

            <div class="launch-form-container">
                <!-- Title -->
                <div class="form-group">
                    <label class="form-label">Title</label>
                    <input type="text" name="title" class="form-input" placeholder="Give your initiative a catchy title." required>
                </div>

                <!-- Event Type -->
                <div class="form-group">
                    <label class="form-label">Event Type</label>
                    <input type="hidden" name="event_type" id="selected_event_type" value="Others">
                    <div class="chips-container" id="event_chips">
                        <div class="chip" data-value="Cleanup Drive">Cleanup Drive</div>
                        <div class="chip" data-value="Tree Planting">Tree Planting</div>
                        <div class="chip" data-value="Waste Management">Waste Management</div>
                        <div class="chip" data-value="Environment Education">Environment Education</div>
                        <div class="chip active" data-value="Others">Others</div>
                    </div>
                </div>

                <!-- Date and time -->
                <div class="form-group">
                    <label class="form-label">Date and time</label>
                    <div class="flex-row gap-12">
                        <div class="input-with-icon">
                            <input type="date" name="date" class="form-input" required>
                        </div>
                        <div class="input-with-icon">
                            <input type="time" name="time" class="form-input" required>
                        </div>
                    </div>
                </div>

                <!-- Address (Restored Original Fields) -->
                <div class="form-group">
                    <label class="form-label">Address</label>
                    <div class="flex-row gap-12" style="margin-bottom: 8px;">
                        <input type="text" name="province" class="form-input" placeholder="Province" required>
                        <input type="text" name="city" class="form-input" placeholder="City" required>
                    </div>
                    <input type="text" name="address_line1" class="form-input" placeholder="Address line 1" style="margin-bottom: 8px;" required>
                    <input type="text" name="address_line2" class="form-input" placeholder="Address line 2" style="margin-bottom: 8px;">
                    <input type="text" name="postal_code" class="form-input" placeholder="Postal Code" required>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-textarea" placeholder="Tell us more about your event..." required></textarea>
                </div>
            </div>

            <!-- Next Button -->
            <div class="bottom-action-container">
                <button type="submit" class="next-btn">NEXT</button>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const eventChips = document.querySelectorAll('#event_chips .chip');
            const hiddenInput = document.getElementById('selected_event_type');
            
            eventChips.forEach(chip => {
                chip.addEventListener('click', function() {
                    eventChips.forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    hiddenInput.value = this.getAttribute('data-value');
                });
            });
        });
    </script>
</body>
</html>
</file>

<file path="webapp/templates/launch_initiative2.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Launch Your Initiative - Part 2</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/launch_initiative.css') }}">
</head>
<body>
    <div class="app-container">
        <!-- Added enctype="multipart/form-data" to allow file uploads -->
        <form method="POST" action="{{ url_for('views.launch_initiative2') }}" enctype="multipart/form-data" class="scroll-content" style="padding-bottom: 40px;">
            <div class="launch-header">
                <a href="{{ url_for('views.launch_initiative1') }}" class="close-btn">
                    <img src="{{ url_for('static', filename='icons/chevron-left.svg') }}" alt="Back">
                </a>
                <h1>Almost There!</h1>
            </div>

            <div class="launch-form-container">
                <!-- Organizing Team -->
                <div class="form-group">
                    <label class="form-label">Organizing Team</label>
                    <input type="hidden" name="org_type" id="selected_org_type" value="Community Group">
                    <div class="chips-container" id="org_chips">
                        <div class="chip" data-value="LGU">LGU</div>
                        <div class="chip" data-value="School">School</div>
                        <div class="chip" data-value="NGO">NGO</div>
                        <div class="chip active" data-value="Community Group">Community Group</div>
                        <div class="chip" data-value="Others">Others</div>
                    </div>
                </div>

                <!-- Name -->
                <div class="form-group">
                    <label class="form-label">Organization Name</label>
                    <input type="text" name="org_name" class="form-input" placeholder="Name of your organization/group" required>
                </div>

                <!-- Contact Person -->
                <div class="form-group">
                    <label class="form-label">Contact Person</label>
                    <div class="flex-row gap-12" style="margin-bottom: 8px;">
                        <input type="text" name="fname" class="form-input" placeholder="First Name" required>
                        <input type="text" name="lname" class="form-input" placeholder="Last Name" required>
                    </div>
                    <input type="text" name="role" class="form-input" placeholder="Role" style="margin-bottom: 8px;" required>
                    <input type="email" name="email" class="form-input" placeholder="Email Address" required>
                </div>

                <!-- Event Source Link -->
                <div class="form-group">
                    <label class="form-label">Event Link (Optional)</label>
                    <input type="url" name="link" class="form-input" placeholder="http://www.eventsourcelink.com/event">
                </div>

                <!-- Event Image Upload -->
                <div class="form-group">
                    <label class="form-label">Event Image</label>
                    <div class="upload-container">
                        <input type="file" id="event-image-upload" name="event_image" class="file-input" accept="image/*" hidden>
                        <div class="upload-box" id="upload-box" onclick="document.getElementById('event-image-upload').click()">
                            <img src="{{ url_for('static', filename='icons/plus.svg') }}" alt="Upload" class="upload-icon">
                            <span class="upload-text" id="upload-status">Upload Image</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="bottom-action-container">
                <button type="submit" class="next-btn" style="background-color: #49A427;">SUBMIT</button>
            </div>
        </form>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Chip selection logic
            const teamChips = document.querySelectorAll('#org_chips .chip');
            const hiddenInput = document.getElementById('selected_org_type');
            
            teamChips.forEach(chip => {
                chip.addEventListener('click', function() {
                    teamChips.forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    hiddenInput.value = this.getAttribute('data-value');
                });
            });

            // File upload UI feedback
            const fileInput = document.getElementById('event-image-upload');
            const uploadStatus = document.getElementById('upload-status');
            const uploadBox = document.getElementById('upload-box');

            fileInput.addEventListener('change', function() {
                if (this.files && this.files[0]) {
                    uploadStatus.textContent = "File: " + this.files[0].name;
                    uploadBox.style.borderColor = "#49A427";
                    uploadBox.style.backgroundColor = "#F0F9ED";
                }
            });
        });
    </script>
</body>
</html>
</file>

