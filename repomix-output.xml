                            <input type="text" class="form-input" placeholder="Last Name">
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Group Name (if applicable)</label>
                        <input type="text" class="form-input" placeholder="Organization or Group Name">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Requester Type</label>
                        <div class="chips-container">
                            <label>
                                <input type="radio" name="requesterType" value="Individual grower" class="chip-option">
                                <span class="chip">Individual grower</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Backyard farmer" class="chip-option">
                                <span class="chip">Backyard farmer</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Community garden member" class="chip-option">
                                <span class="chip">Community garden member</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Student or youth group" class="chip-option">
                                <span class="chip">Student or youth group</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Contact Information</label>
                        <input type="tel" class="form-input" placeholder="Mobile Number" style="margin-bottom: 12px;">
                        <input type="email" class="form-input" placeholder="Email Address (optional)">
                    </div>
                </div>
            </div>

            <!-- Step 3: Directions -->
            <div class="form-step" id="step3">
                 <div class="form-container">
                    <h2 class="section-title">Step 3: Details & Plan</h2>

                    <div class="form-group">
                        <label class="form-label">Location of Farm / Garden</label>
                        <input type="text" class="form-input" placeholder="Province" style="margin-bottom: 8px;">
                        <input type="text" class="form-input" placeholder="Municipality / City" style="margin-bottom: 8px;">
                        <input type="text" class="form-input" placeholder="Barangay">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Type of Growing Area</label>
                         <div class="chips-container">
                            <label>
                                <input type="radio" name="areaType" value="Backyard" class="chip-option">
                                <span class="chip">Backyard</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Community garden" class="chip-option">
                                <span class="chip">Community garden</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="School garden" class="chip-option">
                                <span class="chip">School garden</span>
                            </label>
                            <label>
                                <input type="radio" name="areaType" value="Small farm plot" class="chip-option">
                                <span class="chip">Small farm plot</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Intended Use of Crops*</label>
                        <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Household consumption">
                                Household consumption
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Community sharing">
                                Community sharing
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Feeding programs">
                                Feeding programs
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" name="intendedUse" value="Local selling">
                                Local selling (small-scale only)
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Expected Planting Date</label>
                        <input type="date" class="form-input">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Brief Description of Your Growing Plan*</label>
                        <textarea class="form-textarea" placeholder="Example: “We will plant vegetables in our community garden to support local food needs.”"></textarea>
                    </div>
                </div>
            </div>

            <!-- Step 4: Uploads and Confirmation -->
            <div class="form-step" id="step4">
                 <div class="form-container">
                    <h2 class="section-title">Step 4: Uploads & Confirm</h2>
                    
                    <p style="font-size: 13px; color: #666; margin-bottom: 16px;">Please upload a photo of your growing area.</p>

                    <div class="form-group" style="margin-bottom: 24px;">
                        <div class="upload-container" onclick="document.getElementById('fileUpload').click()">
                            <img src="{{ url_for('static', filename='icons/image.svg') }}" class="upload-icon" alt="Upload">
                            <div class="upload-text">Tap to upload JPG / PNG</div>
                            <input type="file" id="fileUpload" hidden accept="image/png, image/jpeg">
                        </div>
                    </div>

                    <div class="form-group" style="margin-bottom: 24px;">
                         <label class="form-label">Commitment Statement*</label>
                         <div class="checkbox-group">
                            <label class="checkbox-label">
                                <input type="checkbox" required>
                                I will use the seeds responsibly
                            </label>
                            <label class="checkbox-label">
                                <input type="checkbox" required>
                                I understand seeds are not for resale
                            </label>
                             <label class="checkbox-label">
                                <input type="checkbox" id="verifyCheck">
                                I verify that this request is accurate.
                            </label>
                         </div>
                    </div>
                    
                    <div class="disclaimer-text">
                        <p>All requests are subject to verification.</p>
                        <p>Thank you for helping us!</p>
                    </div>

                </div>
            </div>

            <!-- Bottom Action moved inside scroll content (at the end of form) -->
            <div class="bottom-action-container">
                <button type="button" class="action-btn" id="nextBtn" onclick="nextStep()">NEXT</button>
            </div>

        </form>
    </div>

    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function updateView() {
            // Hide all steps
            document.querySelectorAll('.form-step').forEach(step => {
                step.classList.remove('active');
            });
            
            // Show current step
            document.getElementById('step' + currentStep).classList.add('active');

            // Update Header Icon and Link
            const closeBtn = document.querySelector('.close-btn');
            const icon = closeBtn.querySelector('img');

            if (currentStep === 1) {
                // Initial State: X icon, Link to About page
                icon.src = "{{ url_for('static', filename='icons/x.svg') }}";
                closeBtn.href = "{{ url_for('views.about_ecoservice_seeds') }}";
                closeBtn.onclick = null; // Default link behavior
            } else {
                // Secondary State: Chevron Left, Back logic
                icon.src = "{{ url_for('static', filename='icons/chevron-left.svg') }}";
                closeBtn.removeAttribute('href'); // Prevent link navigation
                closeBtn.onclick = function(e) {
                    e.preventDefault();
                    prevStep();
                };
            }

            // Update Button Text
            const btn = document.getElementById('nextBtn');
            if (currentStep === totalSteps) {
                btn.textContent = "FINISH";
                btn.onclick = finishForm;
            } else {
                btn.textContent = "NEXT";
                btn.onclick = nextStep;
            }
        }

        function nextStep() {
            if (currentStep < totalSteps) {
                // Here validation would happen
                currentStep++;
                updateView();
                // Ensure scroll content goes to top
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                currentStep--;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function finishForm() {
            if (document.getElementById('verifyCheck').checked) {
                alert("Request Submitted! (This is a demo)");
                window.location.href = "{{ url_for('views.about_ecoservice_seeds') }}";
            } else {
                alert("Please confirm verification statement.");
            }
        }

        function toggleCropDetails(checkbox, detailsId, itemId) {
            const details = document.getElementById(detailsId);
            const item = document.getElementById(itemId);
            if (checkbox.checked) {
                // Show details, add selected style
                item.classList.add('selected');
                // Optional: Auto focus quantity
                details.querySelector('input').focus();
            } else {
                // Hide details, remove selected style
                item.classList.remove('selected');
                // Cleanup values if needed, or leave them
            }
        }
    </script>
</body>
</html>
</file>

