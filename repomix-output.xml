            {'email': 'tester@gmail.com', 'username': 'EcoTester', 'role': 'Standard'}
        ]
        
        users = {}
        for u in users_data:
            user = User(
                email=u['email'],
                username=u['username'],
                password=generate_password_hash('password123'),
                role=u['role']
            )
            db.session.add(user)
            users[u['role']] = user
        
        db.session.commit()

        # 3. Create Initiatives
        print("Creating initiatives...")
        initiatives = [
            Initiative(
                title="Nabua River Cleanup 2026",
                org_name="LGU Nabua Youth",
