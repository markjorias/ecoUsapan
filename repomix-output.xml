                    </div>
                    <div class="service-info">
                        <div class="service-title">Request Seeds</div>
                        <div class="service-dept">Department of Agriculture</div>
                    </div>
                </a>
                
                <a href="{{ url_for('views.about_ecoservice_seedlings') }}" class="service-card" style="text-decoration: none; color: inherit;">
                    <div class="service-logo-container">
                        <img src="{{ url_for('static', filename='images/DENR.png') }}" alt="DENR Logo" class="service-logo">
                    </div>
                    <div class="service-info">
                        <div class="service-title">Request Tree Seedlings</div>
                        <div class="service-dept">Department of Environment and Natural Resources</div>
                    </div>
                </a>
            </div>
        </div>
        
        {% include 'components/navbar.html' %}
    </div>

    <script>
        document.addEventListener('keydown', function(event) {
            if (event.shiftKey && (event.key === 'L' || event.key === 'l')) {
                window.location.href = "{{ url_for('auth.logout') }}";
            }
        });
    </script>
</body>
</html>
