<file path="webapp/templates/status.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Status - EcoUsapan</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/home.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/status.css') }}">
    <style>
        /* Container Fix to keep Modals inside the "Frame" */
        .app-container {
            position: relative;
            overflow: hidden; /* Keeps shadows and modals from bleeding out */
        }

        /* Modal Base Styles - Changed to absolute to stay within relative parent */
        .modal-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.6);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 16px;
            box-sizing: border-box;
        }
        .modal-content {
            background: white;
            width: 100%;
            max-width: 95%; /* Responsive width within the frame */
            border-radius: 28px;
            padding: 24px;
            max-height: 85vh;
            overflow-y: auto;
            position: relative;
            box-shadow: 0 15px 40px rgba(0,0,0,0.3);
            box-sizing: border-box;
        }
        .modal-close {
            position: absolute;
            top: 20px; right: 20px;
            width: 32px; height: 32px;
            background: #f5f5f5;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 10;
        }

        .modal-title { font-weight: 900; font-size: 20px; margin-bottom: 8px; color: #333; padding-right: 40px; }
        .modal-subtitle { font-size: 12px; font-weight: 700; color: #49A427; text-transform: uppercase; margin-bottom: 16px; display: block; }
        .modal-section-label { font-size: 10px; font-weight: 800; color: #999; text-transform: uppercase; margin: 20px 0 8px 0; display: block; letter-spacing: 0.5px; }
        .modal-text { font-size: 13px; color: #444; line-height: 1.6; white-space: pre-wrap; background: #f9f9f9; padding: 12px; border-radius: 12px; }
        
        .site-photo-container {
            width: 100%;
            height: 180px;
            border-radius: 16px;
            background: #eee;
            margin-top: 8px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #ddd;
        }
        .site-photo-container img { width: 100%; height: 100%; object-fit: cover; }

        /* Confirmation Dialog Overlay */
        #confirmOverlay { z-index: 3000; }
        .confirm-card {
            background: white;
            padding: 24px;
            border-radius: 24px;
            width: 100%;
            max-width: 280px; /* Slimmer for confirmation */
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        }

        .admin-action-row {
            display: flex;
            flex-direction: column; /* Stacked for better mobile space */
            gap: 10px;
            margin-top: 24px;
        }
        .action-btn-full {
            width: 100%;
            padding: 14px;
            border-radius: 14px;
            font-size: 12px;
            font-weight: 800;
            text-transform: uppercase;
            border: none;
            cursor: pointer;
            color: white;
            transition: transform 0.1s;
        }
        .action-btn-full:active { transform: scale(0.96); }
        .btn-approve { background-color: #49A427; }
        .btn-decline { background-color: #C62828; }
        .btn-claim { background-color: #1565C0; }
        .btn-cancel { background-color: #f0f0f0; color: #666; }

        .clickable-card { cursor: pointer; }
        .click-hint { font-size: 9px; color: #999; margin-top: 6px; font-weight: 700; text-transform: uppercase; }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="scroll-content status-scroll-view" style="padding-bottom: 100px;">
            
            <!-- Status Header -->
            <div class="status-header-container">
                <a href="{{ url_for('views.home') }}" style="text-decoration: none; color: inherit; display: flex; align-items: center;">
                    <img src="{{ url_for('static', filename='icons/chevron-left.svg') }}" alt="Back" style="width: 24px; height: 24px; margin-right: 8px;">
                </a>
                <div class="status-header-title">{% if current_user.is_admin %}Management{% else %}Status{% endif %}</div>
            </div>
            
            <!-- 1. Initiatives Section -->
            <div class="section-title">{% if current_user.role == 'Admin_LGU' %}All User Initiatives{% else %}My Initiatives{% endif %}</div>
            <div class="status-list">
                {% if initiatives %}
                    {% for item in initiatives %}
                    <div class="status-card clickable-card"
                        onclick="openInitiativeModal(
                            '{{ item.id }}',
                            '{{ item.title|replace("'", "\\'") }}',
                            '{{ item.org_name|replace("'", "\\'") }}',
                            '{{ item.description|replace("\n", "\\n")|replace("'", "\\'") }}',
                            '{{ item.city }}',
                            '{{ item.province }}',
                            '{{ item.contact_full_name|replace("'", "\\'") }}',
                            '{{ item.contact_role }}',
                            '{{ item.email }}', 
                            '{{ url_for('static', filename='uploads/' + item.image_filename) }}',
                            '{{ item.status }}',
                            {{ 'true' if item.user_id == current_user.id or current_user.role == 'Admin_LGU' else 'false' }}
                        )">
                        <div class="card-header">
                            <div class="card-title">{{ item.title }}</div>
                            <div class="status-badge {{ item.status|lower }}">{{ item.status }}</div>
                        </div>
                        <div class="card-body">
                            <div class="card-thumbnail" style="background-image: url('{{ url_for('static', filename='uploads/' + item.image_filename) }}'); background-size: cover; background-position: center;">
                                {% if item.image_filename == 'default_event.png' %}
                                <img src="{{ url_for('static', filename='icons/map-pin.svg') }}" alt="Initiative" style="width: 20px; opacity: 0.3;">
                                {% endif %}
                            </div>
                            <div class="card-details">
                                <div class="card-subtitle">{{ item.city }}</div>
                                <div class="card-meta">Submitted: {{ item.date_created.strftime('%b %d, %Y') }}</div>
                                <div class="click-hint">Tap to View Details {% if current_user.role == 'Admin_LGU' and item.status == 'Pending' %}& Review{% endif %}</div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p style="font-size: 12px; color: #999; padding: 10px;">No initiatives found.</p>
                {% endif %}
            </div>

            <!-- 2. Participations Section -->
            <div class="section-title">My Participation</div>
            <div class="status-list">
                {% if participations %}
                    {% for p in participations %}
                    <div class="status-card">
                        <div class="card-header">
                            <div class="card-title">{{ p.initiative.title }}</div>
                            <div class="status-badge approved">Registered</div>
                        </div>
                        <div class="card-body">
                            <div class="card-thumbnail">
                                <div style="font-weight: 700; color: #49A427; font-size: 10px; text-transform: uppercase;">EVENT</div>
                            </div>
                            <div class="card-details">
                                <div class="card-subtitle">{{ p.initiative.city }}</div>
                                <div class="card-meta">{{ p.initiative.date }} • {{ p.initiative.time }}</div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p style="font-size: 12px; color: #999; padding: 10px;">No event registrations found.</p>
                {% endif %}
            </div>

            <!-- 3. Service Requests Section -->
            <div class="section-title">{% if current_user.is_admin %}Pending Service Requests{% else %}My Requests{% endif %}</div>
            <div class="status-list">
                {% if requests %}
                    {% for req in requests %}
                    <div class="status-card {% if current_user.is_admin %}clickable-card{% endif %}" 
                         {% if current_user.is_admin %}
                         onclick="openRequestModal(
                            '{{ req.id }}', 
                            '{{ req.item_name }}', 
                            '{{ req.planting_site_desc|replace('\n', '\\n')|replace('\'', '\\\'') }}', 
                            '{% if req.image_filename %}{{ url_for('static', filename='images/userupload/' + req.image_filename) }}{% endif %}',
                            '{{ req.status }}',
                            '{{ req.service_type }}'
                         )"
                         {% endif %}>
                        
                        <div class="card-header">
                            <div class="card-title">{{ req.item_name }}</div>
                            <div class="status-badge {{ req.status|lower }}">{{ req.status }}</div>
                        </div>
                        <div class="card-body">
                            <div class="card-thumbnail">
                                <img src="{{ url_for('static', filename='images/' + ('DENR.png' if req.service_type == 'Seedling' else 'Department-of-Agriculture.png')) }}" alt="Dept" style="width: 30px;">
                            </div>
                            <div class="card-details">
                                <div class="card-subtitle" style="font-weight: 800;">Qty: {{ req.quantity_requested }} Units</div>
                                <div class="card-meta">Submitted: {{ req.date_submitted.strftime('%b %d, %Y') }}</div>
                                
                                {% if current_user.is_admin %}
                                <div class="click-hint">Tap to Review Details</div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% else %}
                    <p style="font-size: 12px; color: #999; padding: 10px;">No service requests found.</p>
                {% endif %}
            </div>
        </div>

        <!-- Initiative Detail Modal Overlay -->
        <div class="modal-overlay" id="initiativeModal" onclick="closeInitiativeModal()">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-close" onclick="closeInitiativeModal()">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" style="width: 14px;">
                </div>
                
                <span class="modal-subtitle" id="initModalStatusDisplay">PENDING INITIATIVE</span>
                <div class="modal-title" id="initModalTitle">Initiative Title</div>
                <div style="font-size: 12px; color: #666; margin-top: -4px;" id="initModalOrg">Organization Name</div>

                <span class="modal-section-label">Description</span>
                <div class="modal-text" id="initModalDescription">Loading description...</div>

                <span class="modal-section-label">Location & Contact</span>
                <div class="modal-text" id="initModalLocation">Loading info...</div>

                <span class="modal-section-label" id="registrantsLabel" style="display: none;">Registered Participants</span>
                <div class="modal-text" id="registrantsList" style="display: none; background: #E8F5E9; border: 1px solid #C8E6C9;"></div>

                <span class="modal-section-label">Initiative Photo</span>
                <div class="site-photo-container">
                    <img id="initModalPhoto" src="" alt="No photo uploaded" onerror="this.src='https://placehold.co/400x200?text=No+Photo+Uploaded';">
                </div>
                
                {% if current_user.role == 'Admin_LGU' %}
                <div id="initAdminActionContainer" class="admin-action-row">
                    <!-- Approval button shown by JS if pending -->
                </div>
                {% endif %}

                <button class="action-btn-full btn-cancel" style="width: 100%; margin-top: 12px;" onclick="closeInitiativeModal()">Close</button>
            </div>
        </div>

        <!-- Detail Modal Overlay for Service Requests -->
        <div class="modal-overlay" id="requestModal" onclick="closeRequestModal()">
            <div class="modal-content" onclick="event.stopPropagation()">
                <div class="modal-close" onclick="closeRequestModal()">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" style="width: 14px;">
                </div>
                
                <span class="modal-subtitle" id="modalStatusDisplay">PENDING REQUEST</span>
                <div class="modal-title" id="modalItemName">Item Name</div>

                <span class="modal-section-label">Requester & Site Information</span>
                <div class="modal-text" id="modalDetails">Loading details...</div>

                <span class="modal-section-label" id="participantLabel" style="display: none;">Registered Participants</span>
                <div class="modal-text" id="participantList" style="display: none; background: #E8F5E9; border: 1px solid #C8E6C9; max-height: 150px; overflow-y: auto;"></div>

                <span class="modal-section-label">Site Photo</span>
                <div class="site-photo-container">
                    <img id="modalSitePhoto" src="" alt="No site photo uploaded" onerror="this.src='https://placehold.co/400x200?text=No+Photo+Uploaded';">
                </div>
                
                {% if current_user.is_admin %}
                <div id="adminActionContainer" class="admin-action-row">
                    <!-- Buttons are dynamically shown/hidden by JS -->
                </div>
                {% endif %}

                <button class="action-btn-full btn-cancel" style="width: 100%; margin-top: 12px;" onclick="closeRequestModal()">Close</button>
            </div>
        </div>

        <!-- Confirmation Dialog Overlay -->
        <div class="modal-overlay" id="confirmOverlay" onclick="closeConfirmModal()">
            <div class="confirm-card" onclick="event.stopPropagation()">
                <h3 style="font-weight: 800; margin-bottom: 12px;" id="confirmTitle">Confirm Action</h3>
                <p style="font-size: 13px; color: #666; margin-bottom: 24px;" id="confirmMessage">Are you sure you want to perform this action?</p>
                
                <div id="confirmationFormContainer">
                    <!-- Dynamic form based on type (GET for initiatives, POST for requests) -->
                </div>
            </div>
        </div>
        
        <!-- Navbar -->
        {% include 'components/navbar.html' %}
    </div>

    <script>
        let activeId = null;
        let activeType = null; // 'initiative' or 'request'
        const userRole = "{{ current_user.role }}";

        // --- Initiative Modal Logic ---
        function openInitiativeModal(id, title, org, desc, city, province, contact, role, email, photoUrl, status, isAuthorized) {
            activeId = id;
            activeType = 'initiative';
            
            // Set text content
            document.getElementById('initModalTitle').innerText = title;
