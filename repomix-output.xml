<file path="webapp/templates/seed_inventory.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Seeds Inventory - EcoUsapan</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/request_services.css') }}">
    <style>
        /* Admin Button Styles */
        .admin-action-btn {
            margin-top: 10px;
            background: #333;
            color: white;
            text-align: center;
            padding: 8px;
