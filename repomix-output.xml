<file path="webapp/static/css/launch_initiative.css">
:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7; /* Apple-like light grey for desktop background */
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden; /* Prevent body scroll, handle in scroll-content */
    box-shadow: var(--shadow);
    border-radius: 40px; /* iPhone corner radius approximation */
    border: 8px solid #333; /* Slight border to simulate bezel */
    
    /* Layout */
    display: flex;
    flex-direction: column;
    align-items: center;
}

.scroll-content {
    width: 100%;
    height: 100%;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-bottom: 110px;
    padding-left: 19px;
    padding-right: 19px;
    
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

/* Launch Initiative Page Styles */

.launch-header {
    width: 100%; /* Adapts to container with padding */
    height: 36px;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0; /* Text aligns with container padding now */
}

.close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    color: #000;
}

.close-btn img {
    width: 24px;
    height: 24px;
}

.launch-header h1 {
    font-size: 24px;
    font-weight: 700;
    color: #000;
}

.launch-form-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0;
    padding: 0;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.form-label {
    font-size: 14px;
    font-weight: 700;
    color: #000;
}

.form-input {
    width: 100%;
    height: 48px;
    border: 1px solid #D1D1D6; /* Assuming a unified border style */
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    font-family: inherit;
    color: #333;
    background-color: #FFFFFF;
}

.form-input:focus {
    outline: none;
    border-color: #49A427;
}

.form-input::placeholder {
    color: #8E8E93;
    font-weight: 400;
}

.chips-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.chip {
    padding: 0; 
    border: 1px solid #E5E5EA; /* Light border */
    border-radius: 20px;
    background-color: #FFFFFF;
    font-size: 11px; /* Slightly smaller for 2-line fit */
    font-weight: 400;
    color: #666;
    cursor: pointer;
    text-align: center;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 44px; /* Uniform height */
    line-height: 1.1;
    flex: 0 0 calc((100% - 16px) / 3); /* Exactly 3 per row with 8px gaps */
}

/* Force Community Group and Others to be on the second line if needed, 
   but with flex-wrap and 5 items, if they are 30% each:
   Row 1: 30+30+30 = 90% + gaps -> Fits 3.
   Row 2: Community Group, Others -> Fill remaining space?
   If we want "Others" to be same width as "Community Group", we let them grow.
   The user image showed 3 top, 2 bottom. LGU, School, NGO look roughly equal. 
   Community Group and Others look roughly equal (wider).
   So flex-grow: 1 should handle this naturally if we set basis correctly.
*/

/* Add active state for demo purposes if needed, though no specific design for active chip provided, usually it turns green or bold */
.chip.active {
    background-color: #49A427 !important;
    color: #FFFFFF !important;
    border-color: #49A427 !important;
}

.flex-row {
    display: flex;
    width: 100%;
}

.gap-12 {
    gap: 12px;
}

.mb-8 {
    margin-bottom: 8px;
}

.mb-12 {
    margin-bottom: 0px;
}

.input-with-icon {
    flex: 1;
    position: relative;
}

/* Optional: Icon handling for date/time if needed specifically styled */
/* .date-input, .time-input {} */

.form-textarea {
    width: 100%;
    height: 140px;
    border: 1px solid #D1D1D6;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 14px;
    font-family: inherit;
    color: #333;
    resize: none;
    background-color: #FFFFFF;
}

.form-textarea:focus {
    outline: none;
    border-color: #49A427;
}

/* Upload Section Styles */
.upload-container {
    width: 100%;
}

.upload-box {
    width: 100%;
    height: 120px;
    border: 2px dashed #D1D1D6;
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    background-color: #F9F9F9;
    transition: all 0.2s ease;
}

.upload-box:hover {
    border-color: #49A427;
    background-color: #F0F9ED;
}

.upload-icon {
    width: 24px;
    height: 24px;
    opacity: 0.5;
}

.upload-text {
    font-size: 14px;
    color: #8E8E93;
    font-weight: 500;
}

.bottom-action-container {
    width: 100%;
    padding: 24px 0; /* Remove horizontal padding since container width is 100% and uses parent padding */
    margin-top: auto; /* Push to bottom if space allows */
}

.next-btn {
    width: 100%;
    height: 50px;
    background-color: #49A427; /* Green */
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 700;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    text-transform: uppercase;
    display: flex;
    justify-content: center;
    align-items: center;
}

/* Mobile Responsive Override */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh; /* Full viewport height */
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px); /* Slightly less default padding on actual mobile if env not supported */
    }
}
