                {% for event in initiatives[:2] %}
                <a href="{{ url_for('views.event_view', id=event.id) }}" class="event-card" style="text-decoration: none; color: inherit;">
                    <div class="event-logo-placeholder" style="background-image: url('{{ url_for('static', filename='uploads/' + event.image_filename) if event.image_filename != 'default_event.png' else '' }}'); background-size: cover; background-position: center;">
                        {% if event.image_filename == 'default_event.png' %}
                        <img src="{{ url_for('static', filename='icons/calendar.svg') }}" style="width: 20px; opacity: 0.2; display: block; margin: 11px auto;">
                        {% endif %}
                    </div>
                    <div class="event-info">
                        <div class="event-org">{{ event.org_name or "Individual" }}</div>
                        <div class="event-title">{{ event.title }}</div>
                        <div class="event-loc">{{ event.city }}</div>
