            teamChips.forEach(chip => {
                chip.addEventListener('click', function() {
                    teamChips.forEach(c => c.classList.remove('active'));
                    this.classList.add('active');
                    hiddenInput.value = this.getAttribute('data-value');
                });
            });

            // File upload UI feedback
            const fileInput = document.getElementById('event-image-upload');
            const uploadStatus = document.getElementById('upload-status');
            const uploadBox = document.getElementById('upload-box');

            fileInput.addEventListener('change', function() {
                if (this.files && this.files[0]) {
                    uploadStatus.textContent = "File: " + this.files[0].name;
                    uploadBox.style.borderColor = "#49A427";
                    uploadBox.style.backgroundColor = "#F0F9ED";
                }
            });
        });
    </script>
</body>
</html>
</file>

