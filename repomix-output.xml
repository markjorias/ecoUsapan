                         <!-- Okra -->
                         <div class="crop-item" id="crop-okra">
                            <label class="crop-header">
                                <div class="crop-title">
                                    <input type="checkbox" name="crops" value="Okra" onchange="toggleCropDetails(this, 'okra-details', 'crop-okra')">
                                    Okra
                                </div>
                            </label>
                            <div class="crop-details" id="okra-details">
                                <div class="form-group" style="margin-bottom: 12px;">
                                    <label class="form-label" style="font-size: 12px;">Quantity</label>
