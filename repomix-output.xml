    flex-direction: column;
    gap: 8px;
    width: 100%;
}

.event-card {
    width: 100%;
    height: 75px;
    padding: 12px 8px;
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 8px;
