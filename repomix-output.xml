<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Forum</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/forum.css') }}">
</head>
<body>
    <div class="app-container">
        <div class="scroll-content" style="padding-bottom: 40px;">
            
            <!-- Header -->
            <div class="forum-header">
                <a href="{{ url_for('views.home') }}" class="back-btn">
                    <img src="{{ url_for('static', filename='icons/chevron-left.svg') }}" alt="Back">
                </a>
                <h1 class="header-title">Forum</h1>
                <button class="filter-btn">
                    <img src="{{ url_for('static', filename='icons/list.svg') }}" alt="Filter">
                </button>
            </div>

            <!-- Search and Add Event Row -->
            <div class="search-add-row">
                <div class="search-container">
                    <div class="search-icon-container">
                        <img src="{{ url_for('static', filename='icons/search.svg') }}" alt="Search" class="search-icon">
                    </div>
                    <div class="search-text-container">
                        <input type="text" class="search-input" placeholder="Search for topics...">
                    </div>
                </div>
                <div class="add-forum-container">
                    <img src="{{ url_for('static', filename='icons/plus.svg') }}" alt="Add Topic" class="add-forum-icon">
                </div>
            </div>

            <!-- Forum Sections -->
            <div class="forum-sections-wrapper">
                
                <!-- Trending Section -->
                <div class="forum-section-container">
                    <h2 class="section-title">Trending</h2>
                    <div class="forum-card-list">
                        <a href="{{ url_for('views.forum_view') }}" style="text-decoration: none; color: inherit; display: block;">
                            <div class="forum-card1">
                                <div class="forum-info">
                                    <div class="forum-tag">News</div>
                                    <div class="forum-title">Trending Topic 1</div>
                                    <div class="forum-meta">
                                        <div class="forum-username">@username</div>
                                        <div class="forum-comments">2.5k comments</div>
                                    </div>
                                </div>
                                <div class="forum-action">  
                                    <div class="vote-controls">
                                        <img src="{{ url_for('static', filename='icons/arrow-up.svg') }}" alt="Upvote" class="vote-icon">
                                        <img src="{{ url_for('static', filename='icons/arrow-down.svg') }}" alt="Downvote" class="vote-icon">
                                    </div>
                                </div>
                            </div>
                        </a>
                        <div class="forum-card2">
                            <div class="forum-info">
                                <div class="forum-tag">Discussion</div>
                                <div class="forum-title">Trending Topic 2</div>
                                <div class="forum-meta">
                                    <div class="forum-username">@username</div>
                                    <div class="forum-comments">2.5k comments</div>
                                </div>
                            </div>
                            <div class="forum-action">  
                                <div class="vote-controls">
                                    <img src="{{ url_for('static', filename='icons/arrow-up.svg') }}" alt="Upvote" class="vote-icon">
                                    <img src="{{ url_for('static', filename='icons/arrow-down.svg') }}" alt="Downvote" class="vote-icon">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

