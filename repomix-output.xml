<file path="app/static/css/request_services.css">
:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7; /* Apple-like light grey for desktop background */
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden; /* Prevent body scroll, handle in scroll-content */
    box-shadow: var(--shadow);
    border-radius: 40px; /* iPhone corner radius approximation */
    border: 8px solid #333; /* Slight border to simulate bezel */
    
    /* Layout */
    display: flex;
    flex-direction: column;
    align-items: center;
}

.scroll-content {
    width: 100%;
    height: 100%;
    overflow-y: auto; /* Allow scrolling */
    overflow-x: hidden;
    scrollbar-width: none; /* Firefox hide scrollbar */
    -ms-overflow-style: none; /* IE/Edge hide scrollbar */
    
    /* Safe area and layout */
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-bottom: 110px; /* Specific to events page style */
    padding-left: 19px;
    padding-right: 19px;
    
    display: flex;
    flex-direction: column;
    align-items: center;
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

/* Request Services Page Styles (Seeds & Seedlings) */

/* Headers */
.request-for-seeds-header,
.request-for-seedlings-header {
    width: 100%; /* Adapts to container with padding */
    height: 36px;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0; /* Text aligns with container padding now */
}

.close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
    color: #000;
}

.close-btn img {
    width: 24px;
    height: 24px;
}

.request-for-seeds-header h1,
.request-for-seedlings-header h1 {
    font-size: 24px;
    font-weight: 700;
    color: #000;
    margin: 0;
    line-height: 36px;
}

/* Search Container */
.search-container {
    width: 100%; /* Adapts to container */
    height: 49px;
    border: 1px solid #E5E5EA;
    border-radius: 59px; /* Pill shape from events.css */
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: 12px;
    gap: 12px;
    margin: 12px auto;
}

.search-icon-container {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.search-icon {
    width: 24px;
    height: 24px;
}

.search-text-container {
    flex: 1;
    display: flex;
    align-items: center;
}

.search-input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #000;
    outline: none;
}

.search-input::placeholder {
    color: #8E8E93;
}

/* Grid Layouts */
.seeds-grid,
.seedlings-grid {
    width: 100%;
    height: auto;
    display: grid;
    grid-template-columns: 1fr 1fr; /* Two equal columns filling space */
    gap: 8px;
    justify-content: center;
    padding: 0; /* Remove padding to align with search container */
}

/* Cards */
.seed-card,
.seedlings-card {
    width: 100%; /* Fill the grid cell */
    height: auto;
    background-color: #F8F7FA;
    border-radius: 12px;
    box-shadow: 0 0 4px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    gap: 8px;
    cursor: pointer;
}

/* Image Containers */
.seed-image-container,
.seedlings-image-container {
    width: 100%; /* Fill the card width */
    aspect-ratio: 1 / 1; /* Keep square aspect ratio */
    height: auto; /* Let aspect-ratio determine height */
    border-radius: 10px;
    overflow: hidden;
    background-color: #F2F2F7;
}

/* Images */
.seed-image,
.seedlings-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Info Containers */
.seed-info,
.seedlings-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px;
}

/* Names */
.seed-name,
.seedlings-name {
    font-size: 18px;
    font-weight: 700;
    color: #000;
}

/* Availability */
.seed-availability,
.seedlings-availability {
    font-size: 14px;
    font-weight: 400;
    color: #666;
}

/* Mobile Responsive Override */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh; /* Full viewport height */
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px); /* Slightly less default padding on actual mobile if env not supported */
    }
}
</file>

