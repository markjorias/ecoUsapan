    border: 1px solid #E5E5EA;
    border-radius: 12px;
    padding: 12px;
}

.comment-header {
    font-size: 8px;
    font-weight: 300;
    color: #666;
    margin-bottom: 4px;
}

.comment-body {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.4;
    color: #333;
    margin-bottom: 12px;
}

.comment-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.comment-interactions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
}

.comment-interaction-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #000;
}

.comment-reply-btn {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #000;
    cursor: pointer;
}

.interaction-icon {
    width: 16px;
    height: 16px;
}

.comment-time {
    font-size: 10px;
    font-weight: 400;
    color: #666;
}

/* Threaded Replies */
.replies-wrapper {
    margin-top: 12px;
    padding-left: 20px;
    border-left: 1px solid #E5E5EA;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
}

.toggle-thread-btn {
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    color: #49A427; /* Using the theme green */
}

.collapse-icon {
    width: 12px;
    height: 12px;
}

.nested-replies-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
}

.reply-card {
    border: none;
    background-color: #F8F7FA;
    padding: 10px;
    border-radius: 8px;
}

/* Inline Reply styles */
.inline-reply-container {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    align-items: center;
}

.inline-reply-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #E5E5EA;
    border-radius: 20px;
    font-size: 12px;
    font-family: inherit;
    outline: none;
    background-color: white;
}

.inline-reply-input:focus {
    border-color: #49A427;
}

.send-reply-btn {
    background-color: #49A427;
    color: white;
    border: none;
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s;
}

.send-reply-btn:hover {
    background-color: #3e8e20;
}

/* Mobile Responsive */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh;
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px);
    }
}
