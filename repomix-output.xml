:root {
    --app-width: 393px;
    --app-height: 852px;
    --bg-color: #f5f5f7;
    --frame-bg: #ffffff;
    --shadow: 0 20px 40px rgba(0,0,0,0.1);
    --primary-green: #4CAF50;
    --accent-green: #49B036;
}

* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

body {
    background-color: var(--bg-color);
    font-family: 'Montserrat', sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

.app-container {
    width: var(--app-width);
    height: var(--app-height);
    background: linear-gradient(180deg, #0B9400 -100%, rgba(0, 0, 0, 0) 35%), var(--frame-bg);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow);
    border-radius: 40px;
    border: 8px solid #333;
    display: flex;
    flex-direction: column;
}

.scroll-content {
    width: 100%;
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-top: max(env(safe-area-inset-top), 74px);
    padding-left: 19px;
    padding-right: 19px;
    padding-bottom: 100px;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.scroll-content::-webkit-scrollbar {
    display: none;
}

/* Header */
.request-for-seedlings-header {
    width: 100%;
    height: 36px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
}

.close-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
}

.close-btn img {
    width: 24px;
    height: 24px;
}

.request-for-seedlings-header h1 {
    font-size: 24px;
    font-weight: 700;
    color: #333333;
    margin: 0;
}

/* Featured Image */
.featured-image-container {
    width: 100%;
    height: 250px;
    border-radius: 16px;
    overflow: hidden;
    flex-shrink: 0;
}

.featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Content */
.content-section {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.seed-title {
    font-size: 24px;
    font-weight: 800;
    color: #333333;
}

.seed-description,
.section-description {
    font-size: 11px;
    font-weight: 400;
    line-height: 1.5;
    color: #666666;
    text-align: justify;
}

.section-title {
    font-size: 24px;
    font-weight: 700;
    color: #333333;
}

/* Button */
.button-container {
    position: absolute;
    bottom: 30px;
    right: 24px;
    display: flex;
    justify-content: flex-end;
}

.request-btn {
    background-color: #49B036;
    color: white;
    border: none;
    padding: 12px 32px;
    border-radius: 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.2s, background-color 0.2s;
}

.request-btn:hover {
    background-color: #3e962e;
}

.request-btn:active {
    transform: scale(0.98);
}

/* Mobile Responsive Override */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
    }

    .app-container {
        width: 100%;
        height: 100vh;
        border-radius: 0;
        box-shadow: none;
        border: none;
    }
}
</file>

