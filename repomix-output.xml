                    <div class="form-group">
                        <label class="form-label">Group Name (if applicable)</label>
                        <input type="text" class="form-input" placeholder="Organization or Group Name">
                        <p style="font-size: 11px; color: #888; margin-top: 4px;">Leave blank if applying as an individual.</p>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Requester Type</label>
                        <div class="chips-container">
                            <label>
                                <input type="radio" name="requesterType" value="Individual environmentalist" class="chip-option">
                                <span class="chip">Individual environmentalist</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Community group / volunteers" class="chip-option">
                                <span class="chip">Community group / volunteers</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Youth or school eco-group" class="chip-option">
                                <span class="chip">Youth or school eco-group</span>
                            </label>
                            <label>
                                <input type="radio" name="requesterType" value="Indigenous community member" class="chip-option">
                                <span class="chip">Indigenous community member</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Contact Information</label>
                        <input type="tel" class="form-input" placeholder="Mobile Number" style="margin-bottom: 12px;">
                        <input type="email" class="form-input" placeholder="Email Address (optional)">
                    </div>
                </div>
            </div>

            <!-- Step 3: Details & Plan -->
            <div class="form-step" id="step3">
                 <div class="form-container">
                    <h2 class="section-title">Step 3: Details & Plan</h2>

                    <!-- Location -->
                    <div class="form-group">
                        <label class="form-label">Location of Planting Site</label>
                        <input type="text" class="form-input" placeholder="Province" style="margin-bottom: 8px;">
                        <input type="text" class="form-input" placeholder="Municipality / City" style="margin-bottom: 8px;">
                        <input type="text" class="form-input" placeholder="Barangay">
                    </div>

                    <!-- Environmental Activity -->
                    <div class="form-group">
                        <label class="form-label">Type of Environmental Activity</label>
                         <div class="chips-container">
                            <label>
                                <input type="radio" name="activityType" value="Tree planting / reforestation" class="chip-option">
                                <span class="chip">Tree planting / reforestation</span>
                            </label>
                            <label>
                                <input type="radio" name="activityType" value="Mangrove planting" class="chip-option">
                                <span class="chip">Mangrove planting</span>
                            </label>
                            <label>
                                <input type="radio" name="activityType" value="Community greening / roadside planting" class="chip-option">
                                <span class="chip">Community greening / roadside planting</span>
                            </label>
                            <label>
                                <input type="radio" name="activityType" value="Watershed or riverbank restoration" class="chip-option">
                                <span class="chip">Watershed or riverbank restoration</span>
                            </label>
                            <label>
                                <input type="radio" name="activityType" value="Home or neighborhood tree growing" class="chip-option">
                                <span class="chip">Home or neighborhood tree growing</span>
                            </label>
                        </div>
                    </div>

                    <!-- Intended Planting Area -->
                    <div class="form-group">
                        <label class="form-label">Intended Planting Area</label>
                        <div class="chips-container">
                            <label>
                                <input type="radio" name="plantingArea" value="Backyard / home area" class="chip-option">
                                <span class="chip">Backyard / home area</span>
                            </label>
                            <label>
                                <input type="radio" name="plantingArea" value="Community space / open land" class="chip-option">
                                <span class="chip">Community space / open land</span>
                            </label>
                            <label>
                                <input type="radio" name="plantingArea" value="Coastal area" class="chip-option">
                                <span class="chip">Coastal area</span>
                            </label>
                            <label>
                                <input type="radio" name="plantingArea" value="Roadside / public space" class="chip-option">
                                <span class="chip">Roadside / public space</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Planned Planting Date</label>
                        <input type="date" class="form-input">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Short Description of Your Activity</label>
                        <p style="font-size: 11px; color: #888; margin-bottom: 8px; margin-top: 0;">Briefly explain why and how you will plant the seedlings. No formal proposal needed.</p>
                        <textarea class="form-textarea" placeholder="Enter description..."></textarea>
                    </div>

                    <!-- Care Commitment (Moved here) -->
                    <div class="form-group">
                        <label class="form-label">Care & Maintenance Commitment*</label>
                        <div class="checkbox-group">
                           <label class="checkbox-label">
                               <input type="checkbox" required>
                               I commit to planting and taking care of the seedlings
                           </label>
                           <label class="checkbox-label">
                               <input type="checkbox" required>
                               I understand that seedlings should not be sold
                           </label>
                        </div>
                   </div>

                </div>
            </div>

            <!-- Step 4: Uploads and Confirmation -->
            <div class="form-step" id="step4">
                 <div class="form-container">
                    <h2 class="section-title">Step 4: Uploads & Confirm</h2>
                    
                    <div class="form-group" style="margin-bottom: 24px;">
                        <label class="form-label" style="font-size: 16px; margin-bottom: 8px;">Required Uploads</label>
                        <p style="font-size: 13px; color: #666; margin-bottom: 4px;">Please upload at least one clear photo to help verify and support your request.</p>
                        
                        <div style="font-size: 12px; color: #444; margin-bottom: 12px; line-height: 1.5;">
                            <strong>Required files:</strong><br>
                            • Photo of the planting site (land, backyard, roadside, coastal area, etc.)<br>
                            • Photo of requester or group at the site (optional if uncomfortable, but recommended)
                        </div>

                        <div class="upload-container" onclick="document.getElementById('fileUpload').click()">
                            <img src="{{ url_for('static', filename='icons/image.svg') }}" class="upload-icon" alt="Upload">
                            <div class="upload-text">Tap to upload JPG / PNG</div>
                            <input type="file" id="fileUpload" hidden accept="image/png, image/jpeg">
                        </div>
                         <p style="font-size: 11px; color: #888; margin-top: 8px;">Note: These photos will only be used to confirm suitability of the request and will not be shared publicly.</p>
                    </div>

                    <div class="disclaimer-text" style="background: #f9f9f9; padding: 16px; border-radius: 8px; font-size: 12px; color: #555; line-height: 1.5; margin-bottom: 24px;">
                        <p>All requests submitted through this app are subject to a due process and verification.</p>
                        <p>Submission of this digital form does not guarantee automatic approval.</p>
                        <p>To ensure fair and proper distribution, additional endorsement or proof (such as a barangay note, community confirmation, or site verification) may be required before a request is approved.</p>
                        <p>You will be notified through the app if additional documents or validation steps are needed.</p>
                        <p style="margin-bottom: 0;">Thank you for helping us keep this program transparent, accountable, and community-focused.</p>
                    </div>

                    <div class="form-group" style="margin-bottom: 24px;">
                         <div class="checkbox-group">
                             <label class="checkbox-label" style="align-items: flex-start;">
                                <input type="checkbox" id="verifyCheck" style="margin-top: 2px;">
                                <span style="line-height: 1.4;">I understand that my request will go through verification and may require endorsement or additional proof.</span>
                            </label>
                         </div>
                    </div>

                </div>
            </div>

            <!-- Bottom Action moved inside scroll content (at the end of form) -->
            <div class="bottom-action-container">
                <button type="button" class="action-btn" id="nextBtn" onclick="nextStep()">NEXT</button>
            </div>

        </form>
    </div>

    <script>
        let currentStep = 1;
        const totalSteps = 4;

        function updateView() {
            // Hide all steps
            document.querySelectorAll('.form-step').forEach(step => {
                step.classList.remove('active');
            });
            
            // Show current step
            document.getElementById('step' + currentStep).classList.add('active');

            // Update Header Icon and Link
            const closeBtn = document.querySelector('.close-btn');
            const icon = closeBtn.querySelector('img');

            if (currentStep === 1) {
                // Initial State: X icon, Link to About page
                icon.src = "{{ url_for('static', filename='icons/x.svg') }}";
                closeBtn.href = "{{ url_for('views.about_ecoservice_seedlings') }}";
                closeBtn.onclick = null; // Default link behavior
            } else {
                // Secondary State: Chevron Left, Back logic
                icon.src = "{{ url_for('static', filename='icons/chevron-left.svg') }}";
                closeBtn.removeAttribute('href'); // Prevent link navigation
                closeBtn.onclick = function(e) {
                    e.preventDefault();
                    prevStep();
                };
            }

            // Update Button Text
            const btn = document.getElementById('nextBtn');
            if (currentStep === totalSteps) {
                btn.textContent = "FINISH";
                btn.onclick = finishForm;
            } else {
                btn.textContent = "NEXT";
                btn.onclick = nextStep;
            }
        }

        function nextStep() {
            if (currentStep < totalSteps) {
                // Here validation would happen
                currentStep++;
                updateView();
                // Ensure scroll content goes to top
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function prevStep() {
            if (currentStep > 1) {
                currentStep--;
                updateView();
                document.querySelector('.scroll-content').scrollTo(0, 0);
            }
        }

        function finishForm() {
            if (document.getElementById('verifyCheck').checked) {
                alert("Request Submitted! (This is a demo)");
                window.location.href = "{{ url_for('views.about_ecoservice_seedlings') }}";
            } else {
                alert("Please confirm verification statement.");
            }
        }

        function toggleCropDetails(checkbox, detailsId, itemId) {
            const details = document.getElementById(detailsId);
            const item = document.getElementById(itemId);
            if (checkbox.checked) {
                // Show details, add selected style
                item.classList.add('selected');
                // Optional: Auto focus quantity
                details.querySelector('input').focus();
            } else {
                // Hide details, remove selected style
                item.classList.remove('selected');
                // Cleanup values if needed, or leave them
            }
        }
    </script>
</body>
</html>
</file>

