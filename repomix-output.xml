    align-items: center;
    /* Optional: background or border if needed for debugging, but user just asked for size */
}

.app-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain; /* Ensure it fits inside without distortion */
}

.nav-grid {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px; /* Adjusted padding */
    width: 354px;
    height: 118px;
    margin-left: auto; /* Center the container */
    margin-right: auto;
}

.nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
}

.nav-square {
    width: 64px;
    height: 64px;
    background-color: #F2F2F7;
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 8px;
}

.nav-square img {
    max-width: 80%; 
    max-height: 80%;
    display: none; /* Hide original img if present, though we will replace it */
}

.nav-icon {
    width: 24px;
    height: 24px;
    background-color: #49A427; /* The requested green color */
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
}

.nav-label {
    font-size: 12px;
    font-weight: 500;
    color: #333;
    text-align: center;
}

.featured-carousel-container {
    width: 326px;
    height: 435px;
    position: relative;
    overflow: visible; /* Changed from hidden to show the shadow */
    border-radius: 20px;
    flex-shrink: 0;
}

.featured-carousel {
    width: 100%;
    height: 100%;
    position: relative;
}

.featured-card {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 0.5s ease-in-out;
    border-radius: 20px;
    overflow: hidden;
    flex-shrink: 0;
    z-index: 1;
    box-shadow: 0 0 4px 0 rgba(73, 164, 39, 0.5); /* Added green drop shadow */
}

.featured-card.active {
    opacity: 1;
    z-index: 2;
}

.carousel-indicators {
    position: absolute;
    top: 16px;
    left: 16px;
    right: 16px;
    display: flex;
    gap: 6px;
    z-index: 20;
}

.indicator-pill {
    flex: 1;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
}

.indicator-pill.active {
    background-color: rgba(255, 255, 255, 0.3); /* Base remains same, progress fills it */
}

.indicator-progress {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    width: 0%;
    background-color: #FFFFFF;
    transition: width 0.1s linear;
}

.featured-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.featured-info-overlay {
    position: absolute;
    bottom: 0;
    left: 0;

    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 16px;
    z-index: 10;
}

.featured-gradient-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, rgba(255, 255, 255, 0) 0%, rgba(86, 193, 46, 0.2) 75%, #219018 100%);
    z-index: 5; /* Below text (10) but above image */
}

.featured-tag {
    width: 78px;
    height: 28px;
    background-color: #219018;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 4px;
}

.featured-title {
    font-size: 16px;
    font-weight: 700;
    color: #F8F7FA;
}

.featured-user {
    font-size: 12px;
    font-weight: 400; /* Regular */
    color: #F8F7FA;
}

.events-container {
    width: 354px;
    height: auto; /* Hug content */
    background-color: #F8F7FA;
    margin-left: auto;
    margin-right: auto;
    flex-shrink: 0; /* Prevent shrinking in flex container */
    border-radius: 10px;
    padding: 12px 14px; /* TB 12, LR 14 */
}

.services-container {
    width: 354px;
    height: auto; /* Hug content */
    background-color: #F8F7FA;
    margin-left: auto;
    margin-right: auto;
    flex-shrink: 0;
    border-radius: 10px;
    padding: 8px 8px;
    display: flex;
    flex-direction: column;
    align-items: center; /* Center children */
}

.events-header {
    width: 328px;
    padding: 8px 8px; /* Top/Bottom 16, Left/Right 20 */
    display: flex;
    align-items: center;
    gap: 8px; /* Space between text and icon */
    font-size: 24px;
    font-weight: 700; /* Bold for header */
    color: #333;
    /* height: 26px?? User said h26. Text 24px line-height usually > 24.
       If strictly h26, content might overflow.
       Padding 16 TB means total height = 26 + 32 = 58px.
       I will assume the *content* height or min-height logic, or just let padding dictate. */
}

.event-card, .event-card-2, .service-card {
    width: 326px;
    height: 75px;
    padding: 12px 8px; /* Top/Bottom 12, Left/Right 8 */
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: 12px; /* Consistent radius */
    margin-bottom: 8px;
}

.event-logo-placeholder {
    width: 42.88px;
    height: 42.88px;
    background-color: #E2E2E2; /* Grey placeholder */
    border-radius: 8px; /* Slightly rounded */
    flex-shrink: 0;
}

.event-info {
    flex: 1; /* Takes available width */
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
}

.event-org {
    font-size: 10px;
    font-weight: 300;
    color: #666;
}

.event-title {
    font-size: 16px;
    font-weight: 700;
    color: #000;
}

.event-loc {
    font-size: 10px;
    font-weight: 300;
    color: #666;
}

.event-action {
    width: 60px;
    height: 28px;
    background-color: #000;
    border-radius: 4px;
    display: flex;
    justify-content: center;
    align-items: center;
    text-transform: uppercase;
    font-size: 8px;
    font-weight: 600;
    color: #FFF;
    cursor: pointer;
    flex-shrink: 0;
}

.separator-container {
    width: 326px;
    height: 26px;
    margin: 0 auto 12px; /* Bottom margin to separate from next content? assumed */
    display: flex;
    align-items: center;
    gap: 12px;
}

.separator-line {
    flex: 1;
    height: 1px;
    background-color: #D1D1D6;
}

.separator-text {
    font-size: 10px;
    font-weight: 300;
    color: #666;
    white-space: nowrap;
}

.launch-initiative-btn {
    width: 326px;
    height: 43px;
    background-color: #49A427;
    padding: 13px 8px; /* Top/Bottom 13, Left/Right 8 */
    margin: 0 auto;
    border-radius: 10px; /* Consistent radius */
    display: flex;
    justify-content: center;
    align-items: center;
    color: #FFFFFF;
    text-transform: uppercase;
    font-weight: 700;
    font-size: 14px; /* Slightly larger than small text */
    cursor: pointer;
}

/* Hide scrollbar for Chrome/Safari/Opera */




.service-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
}

.service-title {
    font-size: 18px;
    font-weight: 700;
    color: #000;
}

.service-dept {
    font-size: 10px;
    font-weight: 300;
    color: #666;
}

.service-logo-container {
    width: 42.88px;
    height: 42.88px;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-shrink: 0;
    background-color: #f8f7fa;
    border-radius: 8px;
}

.service-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
}

/* Bottom Navigation Bar */
.bottom-nav {
    width: 100%;
    height: 99px;
    background-color: #FFFFFF;
    display: flex;
    justify-content: space-around;
    align-items: flex-start; /* Align to top to control vertical spacing */
    padding-top: 15px; /* Spacing from top */
    position: absolute;
    bottom: 0;
    left: 0;
    z-index: 1000;
    border-top: 1px solid #E5E5EA; /* Subtle separator */
}

.nav-bar-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    cursor: pointer;
    color: #8E8E93;
    width: 60px; /* Fixed width for touch target */
    text-decoration: none; /* Remove underline */
}

.nav-bar-item.active {
    color: #49A427;
}

.nav-bar-icon svg {
    width: 24px;
    height: 24px;
}

.nav-bar-label {
    font-size: 10px;
    font-weight: 500;
}

.nav-center-item {
    width: 52px;
    height: 52px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: -10px; /* Slight lift to emphasize? Or just center? Let's keep it aligned for now */
    text-decoration: none;
}

.nav-center-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

/* Mobile Responsive Override */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh; /* Full viewport height */
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px); /* Slightly less default padding on actual mobile if env not supported */
    }
}
</file>

