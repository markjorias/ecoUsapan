    color: #333333;
    white-space: nowrap;
    flex-shrink: 0;
}

/* Forum Image Container */
.forum-image-container {
    width: 100%;
    height: 202px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #F2F2F7;
    flex-shrink: 0;
    margin: 8px 0;
}

.forum-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* Forum Description */
.forum-description {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.forum-description-text {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.5;
    color: #3C3C43;
    margin: 0;
}

/* Forum Interaction Bar */
.forum-interaction-bar {
    width: 100%;
    display: flex;
    gap: 8px;
    flex-direction: column;
}

.interaction-stats {
    display: flex;
    flex-direction: row;
    gap: 12px;
    align-items: center;
}

.vote-pill {
    display: flex;
    flex-direction: row;
    gap: 16px;
    background-color: #F2F2F7;
    padding: 6px 14px;
    border-radius: 20px;
    align-items: center;
}

.vote-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 6px;
}

.stat-icon {
    width: 16px;
    height: 16px;
}

.stat-count {
    font-size: 12px;
    font-weight: 700;
    color: #000;
}

.comment-pill {
    background-color: #F2F2F7;
    padding: 6px 14px;
    border-radius: 20px;
    display: flex;
    align-items: center;
}

.stat-text {
    font-size: 11px;
    font-weight: 400;
    color: #666;
}

.comment-input-container {
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
    background-color: #FFFFFF;
    border: 1px solid #E5E5EA;
    border-radius: 30px;
    padding: 12px 16px;
}

.user-icon {
    width: 24px;
    height: 24px;
    opacity: 0.7;
}

.comment-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 14px;
}

.comment-input::placeholder {
    color: #9E9E9E;
}

/* Comments Section Header */
.comments-section-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px;
}

.comments-title {
    font-size: 12px;
    font-weight: 700;
    color: #333;
}

.comments-filter-btn {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    cursor: pointer;
}

.comments-filter-btn img {
    width: 20px;
    height: 20px;
}

/* Comment Cards */
.comment-list-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.comment-card {
    width: 100%;
    background-color: #FFFFFF;
    border: 1px solid #E5E5EA;
    border-radius: 12px;
    padding: 12px;
}

.comment-header {
    font-size: 8px;
    font-weight: 300;
    color: #666;
    margin-bottom: 4px;
}

.comment-body {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.4;
    color: #333;
    margin-bottom: 12px;
}

.comment-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.comment-interactions {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 12px;
}

.comment-interaction-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #000;
}

.comment-reply-btn {
    background: none;
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
    color: #000;
    cursor: pointer;
}

.interaction-icon {
    width: 16px;
    height: 16px;
}

.comment-time {
    font-size: 10px;
    font-weight: 400;
    color: #666;
}

/* Threaded Replies */
.replies-wrapper {
    margin-top: 12px;
    padding-left: 20px;
    border-left: 1px solid #E5E5EA;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
}

.toggle-thread-btn {
    background: none;
    border: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px 0;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    color: #49A427; /* Using the theme green */
}

.collapse-icon {
    width: 12px;
    height: 12px;
}

.nested-replies-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
}

.reply-card {
    border: none;
    background-color: #F8F7FA;
    padding: 10px;
    border-radius: 8px;
}

/* Inline Reply styles */
.inline-reply-container {
    display: flex;
    gap: 8px;
    margin-top: 10px;
    align-items: center;
}

.inline-reply-input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #E5E5EA;
    border-radius: 20px;
    font-size: 12px;
    font-family: inherit;
    outline: none;
    background-color: white;
}

.inline-reply-input:focus {
    border-color: #49A427;
}

.send-reply-btn {
    background-color: #49A427;
    color: white;
    border: none;
    border-radius: 20px;
    padding: 8px 16px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 0.2s;
}

.send-reply-btn:hover {
    background-color: #3e8e20;
}

/* Mobile Responsive */
@media (max-width: 500px) {
    body {
        background-color: var(--frame-bg);
        align-items: flex-start;
    }

    .app-container {
        width: 100%;
        height: 100vh;
        border-radius: 0;
        box-shadow: none;
        border: none;
        padding-top: env(safe-area-inset-top, 20px);
    }
}
