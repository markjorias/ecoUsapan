            document.getElementById('initModalStatusDisplay').innerText = status + " INITIATIVE";
            
            // Set photo
            const photoImg = document.getElementById('initModalPhoto');
            photoImg.src = (photoUrl && !photoUrl.includes('default_event.png')) ? photoUrl : "https://placehold.co/400x200?text=No+Photo+Uploaded";

            // --- REGISTRANTS LOGIC ---
            const regLabel = document.getElementById('registrantsLabel');
            const regList = document.getElementById('registrantsList');

            if (isAuthorized) {
                regLabel.style.display = 'block';
                regList.style.display = 'block';
                regList.innerHTML = "<em>Loading registrants...</em>";

                fetch(`/get-participants/${id}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.length === 0) {
                            regList.innerHTML = "No participants have registered yet.";
                        } else {
                            regList.innerHTML = data.map(p => `• ${p.name} (${p.email})`).join('<br>');
                        }
                    })
                    .catch(err => {
                        regList.innerHTML = "Error loading participant list.";
                    });
            } else {
                regLabel.style.display = 'none';
                regList.style.display = 'none';
            }

            // Admin Action buttons logic (unchanged)
            const container = document.getElementById('initAdminActionContainer');
            if (container) {
                container.innerHTML = '';
                if (userRole === 'Admin_LGU' && status === 'Pending') {
                    container.innerHTML = `
                        <div style="display: flex; gap: 10px;">
                            <button type="button" class="action-btn-full btn-approve" onclick="askInitiativeConfirmation('Approved')">Approve</button>
                            <button type="button" class="action-btn-full btn-decline" onclick="askInitiativeConfirmation('Declined')">Decline</button>
                        </div>
                    `;
                }
            }
            document.getElementById('initiativeModal').style.display = 'flex';
        }
        
        function closeInitiativeModal() {
            document.getElementById('initiativeModal').style.display = 'none';
        }

        function askInitiativeConfirmation() {
            const container = document.getElementById('confirmationFormContainer');
            document.getElementById('confirmTitle').innerText = "Confirm Approval";
            document.getElementById('confirmMessage').innerText = "Are you sure you want to approve and publish this initiative to the community feed?";
            
            container.innerHTML = `
                <div style="display: flex; gap: 10px;">
                    <button type="button" class="action-btn-full btn-cancel" style="padding: 10px;" onclick="closeConfirmModal()">Cancel</button>
                    <a href="/approve-initiative/${activeId}" class="action-btn-full btn-approve" style="padding: 10px; text-decoration: none; display: flex; align-items: center; justify-content: center;">Confirm</a>
                </div>
            `;
            document.getElementById('confirmOverlay').style.display = 'flex';
        }

        // --- Service Request Modal Logic ---
        function openRequestModal(id, itemName, details, photoUrl, status, serviceType) {
            activeId = id;
            activeType = 'request';
            document.getElementById('modalItemName').innerText = itemName;
            document.getElementById('modalDetails').innerText = details;
            document.getElementById('modalStatusDisplay').innerText = status + " REQUEST";
            
            const photoImg = document.getElementById('modalSitePhoto');
            if (photoUrl && photoUrl !== '' && !photoUrl.includes('undefined')) {
                photoImg.src = photoUrl;
            } else {
                photoImg.src = "https://placehold.co/400x200?text=No+Photo+Uploaded";
            }

            const container = document.getElementById('adminActionContainer');
            if (container) {
                container.innerHTML = ''; 

                let isAuthorized = false;
                if (userRole === 'Admin_DA' && (serviceType === 'Seed' || serviceType === 'Seeds')) {
                    isAuthorized = true;
                } else if (userRole === 'Admin_DENR' && (serviceType === 'Seedling' || serviceType === 'Seedlings')) {
                    isAuthorized = true;
                }

                if (isAuthorized) {
                    if (status === 'Pending') {
                        container.innerHTML += `<button type="button" class="action-btn-full btn-approve" onclick="askRequestConfirmation('Approved')">Approve</button>`;
                        container.innerHTML += `<button type="button" class="action-btn-full btn-decline" onclick="askRequestConfirmation('Declined')">Decline</button>`;
                    } else if (status === 'Approved') {
                        container.innerHTML += `<button type="button" class="action-btn-full btn-claim" onclick="askRequestConfirmation('Claimed')">Mark as Claimed</button>`;
                    } else if (status === 'Declined') {
                        container.innerHTML += `<button type="button" class="action-btn-full btn-approve" onclick="askRequestConfirmation('Pending')">Re-open Request</button>`;
                    }
                }
            }
            document.getElementById('requestModal').style.display = 'flex';
        }

        function closeRequestModal() {
            document.getElementById('requestModal').style.display = 'none';
        }

        function askRequestConfirmation(targetStatus) {
            const container = document.getElementById('confirmationFormContainer');
            document.getElementById('confirmTitle').innerText = `Confirm ${targetStatus}`;
            document.getElementById('confirmMessage').innerText = `Are you sure you want to change this request status to ${targetStatus}? This will finalize the record and update stock levels.`;

            container.innerHTML = `
                <form method="POST" action="/update-request-status/${activeId}">
                    <input type="hidden" name="status" value="${targetStatus}">
                    <div style="display: flex; gap: 10px;">
                        <button type="button" class="action-btn-full btn-cancel" style="padding: 10px;" onclick="closeConfirmModal()">Cancel</button>
                        <button type="submit" class="action-btn-full ${targetStatus === 'Approved' ? 'btn-approve' : targetStatus === 'Declined' ? 'btn-decline' : 'btn-claim'}" style="padding: 10px;">Proceed</button>
                    </div>
                </form>
            `;
            document.getElementById('confirmOverlay').style.display = 'flex';
        }

        function closeConfirmModal() {
            document.getElementById('confirmOverlay').style.display = 'none';
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
                closeConfirmModal();
                closeRequestModal();
                closeInitiativeModal();
            }
        });
    </script>
