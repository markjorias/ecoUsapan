<file path="webapp/templates/forum-view.html">
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ post.title }} - EcoUsapan</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/fonts.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/forum-view.css') }}">
    <style>
        /* Addition to support Up/Down visuals */
        .vote-item { cursor: pointer; transition: all 0.2s; padding: 4px 8px; border-radius: 8px; display: flex; align-items: center; gap: 4px; }
        .vote-item.active-up { background: #E8F5E9; color: #49A427; }
        .vote-item.active-down { background: #FFEBEE; color: #C62828; }
        .vote-item.active-up img { filter: invert(48%) sepia(79%) saturate(452%) hue-rotate(65deg) brightness(95%) contrast(92%); }
        .vote-item.active-down img { filter: invert(20%) sepia(85%) saturate(3000%) hue-rotate(345deg) brightness(90%) contrast(100%); }
        .vote-item img.down-icon { transform: rotate(180deg); }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="scroll-content">
            <!-- Header -->
            <div class="forum-view-header">
                <a href="{{ url_for('views.forum') }}" class="close-btn">
                    <img src="{{ url_for('static', filename='icons/x.svg') }}" alt="Close">
                </a>
                <h1>Forum</h1>
            </div>

            <div class="forum-title-container">
                <span class="forum-username">@{{ post.author.username }}</span>
                <h2 class="forum-main-title">{{ post.title }}</h2>
            </div>

            <div class="forum-interaction-bar">
                <div class="interaction-stats">
                    <div class="vote-pill" style="display: flex; gap: 10px; background: #f5f5f5; padding: 4px; border-radius: 12px; align-items: center;">
                        <!-- Upvote Button -->
                        <div class="vote-item {% if user_vote_type == 'up' %}active-up{% endif %}" id="upvoteBtn" onclick="handleVote('up')">
                            <img src="{{ url_for('static', filename='icons/arrow-up.svg') }}" alt="Up" class="stat-icon">
                        </div>
                        
                        <span class="stat-count" id="totalVotes" style="font-weight: 800; min-width: 20px; text-align: center;">{{ post.votes }}</span>
                        
                        <!-- Downvote Button -->
                        <div class="vote-item {% if user_vote_type == 'down' %}active-down{% endif %}" id="downvoteBtn" onclick="handleVote('down')">
                            <img src="{{ url_for('static', filename='icons/arrow-up.svg') }}" alt="Down" class="stat-icon down-icon">
                        </div>
                    </div>
                    
                    <div class="comment-pill">
                        <span class="stat-text">{{ post.comments|length }} comments</span>
                    </div>
                </div>
            </div>

            <!-- ... (rest of your existing forum-view.html content) ... -->

        </div>
    </div>

    <script>
        async function handleVote(type) {
            const postId = "{{ post.id }}";
            try {
                const response = await fetch(`/vote-post/${postId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 'vote_type': type })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    
                    // Update the number
                    document.getElementById('totalVotes').innerText = data.votes;
                    
                    // Update visual states
                    const upBtn = document.getElementById('upvoteBtn');
                    const downBtn = document.getElementById('downvoteBtn');
                    
                    upBtn.classList.remove('active-up');
                    downBtn.classList.remove('active-down');
                    
                    if (data.status === 'up') {
                        upBtn.classList.add('active-up');
                    } else if (data.status === 'down') {
                        downBtn.classList.add('active-down');
                    }
                }
            } catch (err) {
                console.error("Vote failed", err);
            }
        }
    </script>
</body>
</html>
</file>

